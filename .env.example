# ============================================================
# 108사찰 Multi-tenant 환경변수
# .env.local 파일로 복사하여 값을 채워주세요
# ============================================================

# PostgreSQL (Vercel Postgres, Supabase, Neon 등)
DATABASE_URL="postgresql://user:password@host:5432/k-buddhism?sslmode=require"

# Vercel KV (도메인 매핑 캐시)
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Kakao Login
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
