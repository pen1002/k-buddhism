---
// src/components/temple/TempleFooter.astro — v2 단청
import { parseContact, parseAddress } from '../../lib/cloudinary';
import type { TempleData } from '../../content/config';
interface Props { d: TempleData; }
const { d } = Astro.props;
const addr = parseAddress(d.address);
const cont = parseContact(d.contact);
const links = [
  { label:'행사안내',   href:'#events'   },
  { label:'사찰소개',   href:'#intro'    },
  { label:'사찰갤러리', href:'#gallery'  },
  { label:'법회일정',   href:'#schedule' },
  { label:'인등불사',   href:'#indung'   },
  { label:'오시는 길',  href:'#visit'    },
];
---

<footer style="background:var(--ink,#1A120A);border-top:4px solid transparent;border-image:linear-gradient(to right,var(--dan,#C8372D),var(--hwang-lt,#F0A830),var(--nok,#3A7D44),var(--chung,#2B5BA8)) 1;">
  <div class="w">
    <div class="ft-grid">

      <!-- 사찰 정보 -->
      <div class="ft-wide">
        <div style="display:flex;align-items:center;gap:.7rem;margin-bottom:.8rem;">
          <span style="font-size:1.6rem;">🪷</span>
          <div>
            <p style="font-family:var(--font,serif);font-size:1.1rem;font-weight:700;color:#fff;letter-spacing:.07em;">{d.name}</p>
            {d.name_hanja && <p style="font-family:var(--font,serif);font-size:.62rem;letter-spacing:.38em;color:rgba(240,168,48,.45);margin-top:2px;">{d.name_hanja}</p>}
          </div>
        </div>
        <div style="font-family:var(--font,serif);font-size:.73rem;line-height:2;letter-spacing:.04em;color:rgba(255,255,255,.3);">
          <p>{d.sect}</p>
          {addr.full   && <p>{addr.full}</p>}
          {addr.postal && <p>(우) {addr.postal}</p>}
        </div>
        <div style="display:flex;gap:1.25rem;margin-top:1rem;flex-wrap:wrap;">
          {cont.mobile && <a href={`tel:${cont.mobile.replace(/-/g,'')}`} style="font-family:var(--font,serif);font-size:.72rem;letter-spacing:.08em;color:rgba(240,168,48,.55);">📱 {cont.mobile}</a>}
          {cont.phone  && <a href={`tel:${cont.phone.replace(/-/g,'')}`}  style="font-family:var(--font,serif);font-size:.72rem;letter-spacing:.08em;color:rgba(240,168,48,.55);">☎️ {cont.phone}</a>}
          {cont.email  && <a href={`mailto:${cont.email}`} style="font-family:var(--font,serif);font-size:.72rem;letter-spacing:.08em;color:rgba(240,168,48,.55);">✉️ {cont.email}</a>}
        </div>
      </div>

      <!-- 바로가기 -->
      <div>
        <h3 style="font-family:var(--font,serif);font-size:.82rem;letter-spacing:.2em;color:rgba(255,255,255,.4);margin-bottom:1.1rem;">바로가기</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:.55rem;">
          {links.map(l => (
            <li><a href={l.href} class="ft-a">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- 관련 링크 -->
      <div>
        <h3 style="font-family:var(--font,serif);font-size:.82rem;letter-spacing:.2em;color:rgba(255,255,255,.4);margin-bottom:1.1rem;">관련 링크</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:.55rem;">
          {d.blog_url    && <li><a href={d.blog_url}    target="_blank" rel="noopener noreferrer" class="ft-a">네이버 블로그 ↗</a></li>}
          {d.youtube_url && <li><a href={d.youtube_url} target="_blank" rel="noopener noreferrer" class="ft-a">유튜브 채널 ↗</a></li>}
          {addr.map_url  && <li><a href={addr.map_url}  target="_blank" rel="noopener noreferrer" class="ft-a">네이버 지도 ↗</a></li>}
          <li><a href="/" class="ft-a">Temple Hub ↗</a></li>
        </ul>
      </div>
    </div>

    <!-- 카피라이트 -->
    <div style="border-top:1px solid rgba(255,255,255,.07);padding:1rem 0;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;">
      <p style="font-family:var(--font,serif);font-size:.66rem;letter-spacing:.1em;color:rgba(255,255,255,.18);">
        © {new Date().getFullYear()} {d.name}. All rights reserved.
      </p>
      <p style="font-family:var(--font,serif);font-size:.65rem;letter-spacing:.1em;color:rgba(255,255,255,.12);">
        Temple Hub · Powered by Astro
      </p>
    </div>
  </div>
</footer>

<!-- FAB -->
<a href="#hero"
  style="position:fixed;bottom:1.25rem;right:1.1rem;z-index:40;width:40px;height:40px;display:flex;align-items:center;justify-content:center;background:var(--dan,#C8372D);color:#fff;font-size:.9rem;box-shadow:0 4px 16px rgba(200,55,45,.4);transition:background .2s,transform .2s;"
  aria-label="맨 위로"
  onmouseenter="this.style.transform='translateY(-2px)'"
  onmouseleave="this.style.transform='translateY(0)'"
>↑</a>

<style>
  .ft-grid { display:grid;gap:2.5rem;grid-template-columns:1fr;padding:3.5rem 0 2rem; }
  @media(min-width:640px)  { .ft-grid { grid-template-columns:repeat(2,1fr); } }
  @media(min-width:1024px) { .ft-grid { grid-template-columns:2fr 1fr 1fr; } }
  .ft-wide {}
  @media(min-width:640px)  { .ft-wide { grid-column:span 2; } }
  @media(min-width:1024px) { .ft-wide { grid-column:span 1; } }
  .ft-a { font-family:var(--font,serif);font-size:.75rem;letter-spacing:.08em;color:rgba(255,255,255,.3); }
  .ft-a:hover { color:rgba(240,168,48,.65); }
</style>
