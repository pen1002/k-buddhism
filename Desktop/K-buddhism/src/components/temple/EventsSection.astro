---
// src/components/temple/EventsSection.astro — 공지사항·기도·법회·행사 v3
import type { TempleData } from '../../content/config';
interface Props { d: TempleData; }
const { d } = Astro.props;
const evs = d.events ?? [];

// 탭 정의
const tabs = [
  { key:'all',        label:'전체' },
  { key:'prayer',     label:'기도' },
  { key:'service',    label:'법회' },
  { key:'festival',   label:'불교4대명절' },
  { key:'templestay', label:'상시행사' },
];
---

<section id="events" class="ev-sec" aria-labelledby="ev-ttl">

  <!-- 단청 헤더 -->
  <div class="ev-header">
    <div class="ev-inner">
      <span class="ev-en">notice &amp; events</span>
      <h2 id="ev-ttl" class="ev-title">공지사항 · 기도 · 법회 · 행사</h2>
      <p class="ev-desc">기도법회 및 주요 행사 일정을 안내드립니다</p>
    </div>
  </div>

  <!-- 티커 바 — 빠른 속도 -->
  {evs.length > 0 && (
    <div class="ticker-wrap">
      <div class="ticker-inner">
        <span class="ticker-lbl">📅 최신 공지</span>
        <div class="ticker-scroll">
          <div class="ticker-t">
            {[...evs,...evs,...evs].map(ev=>(
              <span class="ticker-item">
                {(ev.schedule||ev.time) && <span class="ticker-dt">{ev.schedule??ev.time}</span>}
                <span>{ev.emoji ?? ''} {ev.name}</span>
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  )}

  <div class="w">
    <!-- 탭 필터 -->
    <div class="ev-tabs">
      {tabs.map((t,i) => (
        <button class={`ev-tab${i===0?' on':''}`} onclick={`filterEv(this,'${t.key}')`}>{t.label}</button>
      ))}
    </div>

    <!-- 카드 그리드 -->
    <div class="ev-grid">
      {evs.length > 0 ? evs.map((ev, i) => (
        <div class="ev-card" data-cat={ev.category ?? 'prayer'}>
          <span class={`ev-date c${(i%4)+1}`}>{ev.schedule ?? ev.time ?? '상시'}</span>
          {ev.time && ev.schedule && <span class="ev-time">⏰ {ev.time}</span>}
          <h3 class="ev-name">{ev.emoji && <span>{ev.emoji} </span>}{ev.name}</h3>
          {ev.note     && <p class="ev-note">{ev.note}</p>}
          {ev.location && <p class="ev-loc">📍 {ev.location}</p>}
        </div>
      )) : (
        <p class="ev-empty">공지사항을 등록하시면 이곳에 표시됩니다.</p>
      )}
    </div>
  </div>
</section>

<style>
  .ev-sec { background:var(--bg,#FDFAF4);padding:5rem 0 5.5rem;scroll-margin-top:64px; }

  .ev-header {
    background:linear-gradient(135deg,#C8372D 0%,#9C1F18 100%);
    padding:2.5rem 1.4rem 2rem;text-align:center;margin-bottom:2rem;
    position:relative;overflow:hidden;
  }
  .ev-header::before {
    content:'';position:absolute;inset:0;
    background-image:radial-gradient(circle at 20% 50%,rgba(255,255,255,.07) 0%,transparent 55%),
                     radial-gradient(circle at 80% 50%,rgba(240,168,48,.12) 0%,transparent 45%);
  }
  .ev-inner { position:relative;z-index:1; }
  .ev-en    { font-family:var(--font,serif);font-size:.6rem;letter-spacing:.32em;text-transform:uppercase;font-style:italic;color:rgba(255,255,255,.55); }
  .ev-title { font-family:var(--font,serif);font-size:clamp(1.5rem,4vw,2.3rem);font-weight:900;color:#fff;letter-spacing:.08em;margin-top:.25rem;word-break:keep-all; }
  .ev-desc  { font-family:var(--font,serif);font-size:.78rem;letter-spacing:.08em;color:rgba(255,255,255,.7);margin-top:.35rem; }

  /* 티커 — 빠름 */
  .ticker-wrap  { background:#C8372D;padding:.5rem 0;overflow:hidden;margin-bottom:1.8rem; }
  .ticker-inner { display:flex;align-items:center;gap:1rem;padding:0 1.4rem; }
  .ticker-lbl   { flex-shrink:0;font-family:var(--font,serif);font-size:.65rem;letter-spacing:.2em;color:#fff;padding-right:.9rem;border-right:1px solid rgba(255,255,255,.3);white-space:nowrap; }
  .ticker-scroll{ overflow:hidden;flex:1;min-width:0; }
  /* 속도 22s (기존 40s보다 빠름) */
  .ticker-t     { display:inline-flex;gap:2.5rem;white-space:nowrap;animation:tick 22s linear infinite; }
  .ticker-t:hover{ animation-play-state:paused; }
  .ticker-item  { display:inline-flex;align-items:center;gap:.4rem;font-family:var(--font,serif);font-size:.74rem;color:rgba(255,255,255,.85); }
  .ticker-dt    { font-style:italic;color:rgba(255,255,255,.48); }
  @keyframes tick { from{transform:translateX(0)} to{transform:translateX(-33.333%)} }

  /* 탭 */
  .ev-tabs { display:flex;gap:.4rem;margin-bottom:1.5rem;flex-wrap:wrap; }
  .ev-tab  { padding:.4rem .95rem;font-family:var(--font,serif);font-size:.7rem;letter-spacing:.08em;border:1.5px solid rgba(200,55,45,.22);color:#6B5340;cursor:pointer;transition:all .18s;background:#fff; }
  .ev-tab:hover,.ev-tab.on { background:#C8372D;color:#fff;border-color:#C8372D; }

  /* 카드 */
  .ev-grid { display:grid;gap:.9rem;grid-template-columns:1fr; }
  @media(min-width:540px)  { .ev-grid{grid-template-columns:repeat(2,1fr)} }
  @media(min-width:1024px) { .ev-grid{grid-template-columns:repeat(4,1fr)} }

  .ev-card {
    background:#fff;border-top:4px solid #C8372D;
    padding:1.3rem 1.2rem;
    box-shadow:0 2px 10px rgba(26,18,10,.06);
    transition:transform .2s,box-shadow .2s;
  }
  .ev-card:hover { transform:translateY(-3px);box-shadow:0 8px 22px rgba(26,18,10,.11); }
  .ev-card:nth-child(4n+2){border-top-color:#2B5BA8}
  .ev-card:nth-child(4n+3){border-top-color:#3A7D44}
  .ev-card:nth-child(4n+4){border-top-color:#D4820A}

  .ev-date { display:inline-block;padding:.12rem .52rem;font-family:var(--font,serif);font-size:.63rem;letter-spacing:.12em;background:#FDE8E6;color:#C8372D;margin-bottom:.55rem; }
  .ev-date.c2{background:#E6EEF8;color:#2B5BA8}
  .ev-date.c3{background:#E6F3E8;color:#3A7D44}
  .ev-date.c4{background:#FEF3DC;color:#D4820A}
  .ev-time { display:block;font-family:var(--font,serif);font-size:.62rem;color:#9C7E65;margin-bottom:.35rem; }

  .ev-name  { font-family:var(--font,serif);font-size:.97rem;font-weight:700;color:#1A120A;line-height:1.55;letter-spacing:.04em;margin-bottom:.4rem;word-break:keep-all; }
  .ev-note  { font-family:var(--font,serif);font-size:.73rem;color:#6B5340;line-height:1.8;letter-spacing:.03em;word-break:keep-all; }
  .ev-loc   { font-family:var(--font,serif);font-size:.68rem;color:#9C7E65;margin-top:.25rem; }
  .ev-empty { font-family:var(--font,serif);font-size:.9rem;color:#6B5340;grid-column:1/-1; }
</style>

<script>
  function filterEv(btn: HTMLElement, cat: string) {
    document.querySelectorAll('.ev-tab').forEach(b => b.classList.remove('on'));
    btn.classList.add('on');
    document.querySelectorAll<HTMLElement>('.ev-card').forEach(c => {
      c.style.display = (cat === 'all' || c.dataset.cat === cat) ? '' : 'none';
    });
  }
  (window as any).filterEv = filterEv;
</script>
