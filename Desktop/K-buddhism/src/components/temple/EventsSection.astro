---
// EventsSection.astro — v4: 행사안내 티커 → 이달의 주요행사 → 공지사항 탭+카드
import type { TempleData } from '../../content/config';
interface Props { d: TempleData; }
const { d } = Astro.props;
const evs = d.events ?? [];

// 이달의 주요행사 — festival + prayer 중 앞 3개
const featured = evs.filter(e => ['festival','prayer','service'].includes(e.category ?? '')).slice(0,3);
// 전체 탭
const tabs = [
  { key:'all',        label:'전체' },
  { key:'prayer',     label:'기도' },
  { key:'service',    label:'법회' },
  { key:'festival',   label:'불교4대명절' },
  { key:'templestay', label:'상시행사' },
];
const catColor: Record<string,string> = {
  prayer:'#C8372D', service:'#2B5BA8', festival:'#D4820A', templestay:'#3A7D44'
};
---

<!-- ① 행사안내 — 얇은 티커 바 (공지 성격) -->
{evs.length > 0 && (
  <div class="notice-bar" aria-label="행사안내">
    <span class="nb-lbl">📢 행사안내</span>
    <div class="nb-track-wrap">
      <div class="nb-track">
        {[...evs,...evs,...evs].map(ev => (
          <span class="nb-item">
            {ev.emoji && <span>{ev.emoji}</span>}
            {(ev.schedule || ev.time) && <em class="nb-dt">{ev.schedule ?? ev.time}</em>}
            <span class="nb-name">{ev.name}</span>
          </span>
        ))}
      </div>
    </div>
  </div>
)}

<!-- ② 이달의 주요행사 — 최신 소식 하이라이트 박스 -->
{featured.length > 0 && (
  <div class="featured-wrap" aria-label="이달의 주요행사">
    <div class="fw-inner w">
      <div class="fw-label">
        <span class="fw-en">this month</span>
        <h2 class="fw-title">이달의 주요행사</h2>
      </div>
      <div class="fw-cards">
        {featured.map((ev, i) => (
          <div class="fw-card" style={`border-left-color:${catColor[ev.category??'prayer']??'#C8372D'}`}>
            <span class="fw-emoji">{ev.emoji ?? '📅'}</span>
            <div>
              <p class="fw-name">{ev.name}</p>
              <p class="fw-date">{ev.schedule ?? ev.time ?? '상시'}</p>
              {ev.note && <p class="fw-note">{ev.note}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
)}

<!-- ③ 공지사항·기도·법회·행사 — 탭 + 카드 그리드 -->
<section id="events" class="ev-sec" aria-labelledby="ev-ttl">

  <!-- 단청 헤더 -->
  <div class="ev-header">
    <span class="ev-en">notice &amp; events</span>
    <h2 id="ev-ttl" class="ev-title">공지사항 · 기도 · 법회 · 행사</h2>
    <p class="ev-desc">기도법회 및 주요 행사 일정을 안내드립니다</p>
  </div>

  <div class="w">
    <!-- 탭 -->
    <div class="ev-tabs">
      {tabs.map((t,i)=>(
        <button class={`ev-tab${i===0?' on':''}`} onclick={`filterEv(this,'${t.key}')`}>{t.label}</button>
      ))}
    </div>

    <!-- 카드 그리드 -->
    <div class="ev-grid">
      {evs.length > 0 ? evs.map((ev,i) => (
        <div class="ev-card" data-cat={ev.category ?? 'prayer'}>
          <span class={`ev-date c${(i%4)+1}`}>{ev.schedule ?? ev.time ?? '상시'}</span>
          {ev.time && ev.schedule && <span class="ev-time">⏰ {ev.time}</span>}
          <h3 class="ev-name">{ev.emoji && <span>{ev.emoji} </span>}{ev.name}</h3>
          {ev.note     && <p class="ev-note">{ev.note}</p>}
          {ev.location && <p class="ev-loc">📍 {ev.location}</p>}
        </div>
      )) : (
        <p class="ev-empty">공지사항을 등록하시면 이곳에 표시됩니다.</p>
      )}
    </div>
  </div>
</section>

<style>
/* ── ① 행사안내 티커 바 ── */
.notice-bar {
  background:#C8372D;
  display:flex;align-items:center;
  padding:.45rem 0;overflow:hidden;
  position:sticky;top:60px;z-index:70;
  box-shadow:0 2px 8px rgba(200,55,45,.3);
}
.nb-lbl {
  flex-shrink:0;
  padding:0 1rem;
  font-family:var(--font,serif);font-size:.65rem;
  letter-spacing:.22em;color:#fff;font-weight:700;
  border-right:1px solid rgba(255,255,255,.3);
  white-space:nowrap;
}
.nb-track-wrap { overflow:hidden;flex:1;min-width:0; }
.nb-track {
  display:inline-flex;gap:2.5rem;white-space:nowrap;
  padding:0 1rem;
  animation:nbscroll 24s linear infinite;
}
.nb-track:hover { animation-play-state:paused; }
.nb-item { display:inline-flex;align-items:center;gap:.4rem;font-family:var(--font,serif);font-size:.72rem;color:rgba(255,255,255,.88); }
.nb-dt   { color:rgba(255,255,255,.5);font-style:italic; }
.nb-name { font-weight:600; }
@keyframes nbscroll { from{transform:translateX(0)} to{transform:translateX(-33.333%)} }

/* ── ② 이달의 주요행사 ── */
.featured-wrap {
  background:linear-gradient(135deg,#1A120A 0%,#2D1C10 50%,#1A120A 100%);
  padding:2.2rem 0;
}
.fw-inner {
  display:grid;
  grid-template-columns:max-content 1fr;
  gap:2.5rem;align-items:center;
}
@media(max-width:767px) { .fw-inner{grid-template-columns:1fr;gap:1.2rem;} }
.fw-label {}
.fw-en    { font-family:var(--font,serif);font-size:.6rem;letter-spacing:.3em;color:#D4820A;text-transform:uppercase;font-style:italic; }
.fw-title { font-family:var(--font,serif);font-size:clamp(1.2rem,3vw,1.7rem);font-weight:900;color:#fff;letter-spacing:.08em;margin-top:.2rem;white-space:nowrap; }

.fw-cards { display:flex;gap:1rem;flex-wrap:wrap; }
.fw-card  {
  flex:1;min-width:200px;
  display:flex;align-items:flex-start;gap:.8rem;
  padding:1rem 1.2rem;
  background:rgba(255,255,255,.06);
  border-left:3px solid #C8372D;
  backdrop-filter:blur(4px);
  transition:background .2s;
}
.fw-card:hover { background:rgba(255,255,255,.1); }
.fw-emoji { font-size:1.5rem;flex-shrink:0;margin-top:.1rem; }
.fw-name  { font-family:var(--font,serif);font-size:.92rem;font-weight:700;color:#fff;letter-spacing:.05em;word-break:keep-all; }
.fw-date  { font-family:var(--font,serif);font-size:.68rem;color:#D4820A;margin-top:.2rem;letter-spacing:.08em; }
.fw-note  { font-family:var(--font,serif);font-size:.68rem;color:rgba(255,255,255,.55);margin-top:.25rem;word-break:keep-all;line-height:1.7; }

/* ── ③ 공지사항 섹션 ── */
.ev-sec { background:var(--bg,#FDFAF4);padding:4.5rem 0 5.5rem;scroll-margin-top:64px; }

.ev-header {
  background:linear-gradient(135deg,#C8372D,#9C1F18);
  padding:2.2rem 1.4rem 1.8rem;text-align:center;margin-bottom:1.8rem;
  position:relative;overflow:hidden;
}
.ev-header::before {
  content:'';position:absolute;inset:0;
  background:radial-gradient(circle at 80%,rgba(240,168,48,.12) 0%,transparent 50%);
}
.ev-en    { font-family:var(--font,serif);font-size:.58rem;letter-spacing:.32em;text-transform:uppercase;font-style:italic;color:rgba(255,255,255,.5); }
.ev-title { font-family:var(--font,serif);font-size:clamp(1.4rem,3.8vw,2.2rem);font-weight:900;color:#fff;letter-spacing:.08em;margin-top:.2rem;word-break:keep-all; }
.ev-desc  { font-family:var(--font,serif);font-size:.75rem;color:rgba(255,255,255,.65);margin-top:.3rem; }

/* 탭 */
.ev-tabs { display:flex;gap:.4rem;margin-bottom:1.4rem;flex-wrap:wrap; }
.ev-tab  { padding:.38rem .9rem;font-family:var(--font,serif);font-size:.68rem;letter-spacing:.08em;border:1.5px solid rgba(200,55,45,.2);color:#6B5340;cursor:pointer;transition:all .18s;background:#fff; }
.ev-tab:hover,.ev-tab.on { background:#C8372D;color:#fff;border-color:#C8372D; }

/* 카드 */
.ev-grid { display:grid;gap:.8rem;grid-template-columns:1fr; }
@media(min-width:540px)  { .ev-grid{grid-template-columns:repeat(2,1fr)} }
@media(min-width:1024px) { .ev-grid{grid-template-columns:repeat(4,1fr)} }

.ev-card {
  background:#fff;border-top:3px solid #C8372D;
  padding:1.2rem 1.1rem;
  box-shadow:0 2px 8px rgba(26,18,10,.05);
  transition:transform .2s,box-shadow .2s;
}
.ev-card:hover { transform:translateY(-3px);box-shadow:0 8px 20px rgba(26,18,10,.1); }
.ev-card:nth-child(4n+2){border-top-color:#2B5BA8}
.ev-card:nth-child(4n+3){border-top-color:#3A7D44}
.ev-card:nth-child(4n+4){border-top-color:#D4820A}

.ev-date { display:inline-block;padding:.1rem .5rem;font-family:var(--font,serif);font-size:.61rem;letter-spacing:.1em;background:#FDE8E6;color:#C8372D;margin-bottom:.5rem; }
.ev-date.c2{background:#E6EEF8;color:#2B5BA8} .ev-date.c3{background:#E6F3E8;color:#3A7D44} .ev-date.c4{background:#FEF3DC;color:#D4820A}
.ev-time  { display:block;font-family:var(--font,serif);font-size:.6rem;color:#9C7E65;margin-bottom:.3rem; }
.ev-name  { font-family:var(--font,serif);font-size:.95rem;font-weight:700;color:#1A120A;line-height:1.5;letter-spacing:.04em;margin-bottom:.4rem;word-break:keep-all; }
.ev-note  { font-family:var(--font,serif);font-size:.72rem;color:#6B5340;line-height:1.8;letter-spacing:.03em;word-break:keep-all; }
.ev-loc   { font-family:var(--font,serif);font-size:.67rem;color:#9C7E65;margin-top:.2rem; }
.ev-empty { font-family:var(--font,serif);font-size:.9rem;color:#6B5340;grid-column:1/-1; }
</style>

<script>
  function filterEv(btn: HTMLElement, cat: string) {
    document.querySelectorAll('.ev-tab').forEach(b => b.classList.remove('on'));
    btn.classList.add('on');
    document.querySelectorAll<HTMLElement>('.ev-card').forEach(c => {
      c.style.display = (cat === 'all' || c.dataset.cat === cat) ? '' : 'none';
    });
  }
  (window as any).filterEv = filterEv;
</script>
