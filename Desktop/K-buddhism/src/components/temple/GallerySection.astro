---
// src/components/temple/GallerySection.astro — 사찰갤러리 2행 v2
import { gallery as glUrl } from '../../lib/cloudinary';
import type { TempleData } from '../../content/config';
interface Props { d: TempleData; }
const { d } = Astro.props;

// gallery 또는 gallery_imgs 지원
type GItem = { id:string; src:string; cap:string; sub:string; tag:string; };
let items: GItem[] = [];
if (d.gallery?.length) {
  items = d.gallery.map(g => ({
    id:  g.id,
    src: glUrl(g.id, 800, 600),
    cap: g.cap ?? '',
    sub: g.sub ?? '',
    tag: g.tag ?? '',
  }));
} else if (d.gallery_imgs?.length) {
  items = d.gallery_imgs.map((id, i) => ({
    id, src: glUrl(id, 800, 600), cap: '', sub: '', tag: '',
  }));
}

// 단청 태그 색상 순환
const tagColors = ['tag-dan','tag-chung','tag-nok','tag-hwang'];

const row1 = items.slice(0, 3);   // 1행: 처음 3개 (첫번째 와이드)
const row2 = items.slice(3, 6);   // 2행: 다음 3개
const show = items.length > 0;
---

{show && (
  <section id="gallery" style="background:var(--bg,#FDFAF4);padding:5.5rem 0 6rem;scroll-margin-top:64px;" aria-labelledby="gal-ttl">
    <div class="w">
      <span class="sec-en" style="color:var(--nok,#3A7D44);">photo gallery</span>
      <h2 id="gal-ttl" class="sec-h2" style="font-size:clamp(2rem,4.5vw,3rem);margin-top:.3rem;">사찰갤러리</h2>
      <div class="dc-bar"><span class="b3"></span><span class="b2"></span><span class="b1"></span><span class="b4"></span></div>

      <!-- 1행 -->
      {row1.length > 0 && (
        <div class="gal-row1" style="margin-bottom:6px;">
          {row1.map((g, i) => (
            <div class={`gi ${i===0 ? 'gi-wide' : ''}`} style={`height:${i===0 ? 320 : 320}px;`}>
              <img
                src={i===0 ? glUrl(g.id,900,520) : glUrl(g.id,600,520)}
                alt={g.cap || `사찰 사진 ${i+1}`}
                loading={i===0 ? 'eager' : 'lazy'}
                onerror="this.parentElement.style.background='#e8e0d5'"
              />
              <div class="gi-ov"></div>
              {g.tag && <span class={`gal-tag ${tagColors[i%4]}`}>{g.tag}</span>}
              {(g.cap||g.sub) && (
                <div class="gi-cap">
                  {g.cap && <p class="gc-t">{g.cap}</p>}
                  {g.sub && <p class="gc-s">{g.sub}</p>}
                </div>
              )}
            </div>
          ))}
        </div>
      )}

      <!-- 2행 -->
      {row2.length > 0 && (
        <div class="gal-row2">
          {row2.map((g, i) => (
            <div class="gi" style="height:260px;">
              <img
                src={glUrl(g.id, 640, 380)}
                alt={g.cap || `사찰 사진 ${i+4}`}
                loading="lazy"
                onerror="this.parentElement.style.background='#e8e0d5'"
              />
              <div class="gi-ov"></div>
              {g.tag && <span class={`gal-tag ${tagColors[(i+3)%4]}`}>{g.tag}</span>}
              {(g.cap||g.sub) && (
                <div class="gi-cap">
                  {g.cap && <p class="gc-t">{g.cap}</p>}
                  {g.sub && <p class="gc-s">{g.sub}</p>}
                </div>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
)}

<style>
  .gal-row1 { display:grid;grid-template-columns:repeat(3,1fr);gap:6px; }
  .gal-row2 { display:grid;grid-template-columns:repeat(3,1fr);gap:6px; }
  @media(max-width:639px) {
    .gal-row1,.gal-row2 { grid-template-columns:1fr; }
    .gi-wide { grid-column:span 1 !important; }
  }
  .gi-wide { grid-column:span 2; }

  .gi { position:relative;overflow:hidden;background:var(--bg2,#F5EFE0); }
  .gi img { width:100%;height:100%;object-fit:cover;transition:transform .6s cubic-bezier(.22,1,.36,1); }
  .gi:hover img { transform:scale(1.06); }
  .gi-ov { position:absolute;inset:0;background:linear-gradient(to top,rgba(26,18,10,.8) 0%,transparent 55%);opacity:0;transition:opacity .3s; }
  .gi:hover .gi-ov { opacity:1; }
  .gi-cap { position:absolute;bottom:0;inset-x:0;padding:.9rem 1rem;opacity:0;transform:translateY(6px);transition:opacity .3s,transform .3s; }
  .gi:hover .gi-cap { opacity:1;transform:translateY(0); }
  .gc-t { font-family:var(--font,serif);font-size:.9rem;font-weight:700;color:#fff;letter-spacing:.05em; }
  .gc-s { font-family:var(--font,serif);font-size:.7rem;color:rgba(255,255,255,.6);margin-top:.1rem; }

  .gal-tag {
    position:absolute;top:.65rem;left:.65rem;z-index:2;
    padding:.12rem .55rem;font-family:var(--font,serif);font-size:.62rem;letter-spacing:.12em;color:#fff;
  }
  .tag-dan   { background:var(--dan,#C8372D); }
  .tag-chung { background:var(--chung,#2B5BA8); }
  .tag-nok   { background:var(--nok,#3A7D44); }
  .tag-hwang { background:var(--hwang,#D4820A); }
</style>
