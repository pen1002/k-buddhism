---
// src/components/temple/IndungSection.astro — 인등불사 + 스마트페이 v2
import type { TempleData } from '../../content/config';
interface Props { d: TempleData; }
const { d } = Astro.props;
const ind = d.indung;
const hasTypes = ind?.types && ind.types.length > 0;
const colors = ['var(--dan,#C8372D)','var(--chung,#2B5BA8)','var(--nok,#3A7D44)','var(--hwang,#D4820A)'];
const topColors = ['#C8372D','#2B5BA8','#3A7D44','#D4820A'];
---

{ind && (
  <section id="indung" style="background:var(--bg,#FDFAF4);padding:5.5rem 0 6rem;scroll-margin-top:64px;position:relative;overflow:hidden;" aria-labelledby="ind-ttl">
    <!-- 배경 장식 -->
    <div aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;background-image:radial-gradient(circle at 10% 20%,rgba(200,55,45,.05) 0%,transparent 50%),radial-gradient(circle at 90% 80%,rgba(43,91,168,.05) 0%,transparent 50%);"></div>

    <div class="w" style="position:relative;">

      <!-- 인등 헤더 -->
      <div style="text-align:center;padding:3.5rem 1.4rem 3rem;background:linear-gradient(135deg,var(--hwang-bg,#FEF3DC) 0%,#FFFBF0 50%,var(--dan-bg,#FDE8E6) 100%);border:1.5px solid rgba(212,130,10,.2);margin-bottom:2.5rem;position:relative;">
        <div aria-hidden="true" style="position:absolute;top:50%;left:1.5rem;font-size:1.8rem;opacity:.2;transform:translateY(-50%);">🪷</div>
        <div aria-hidden="true" style="position:absolute;top:50%;right:1.5rem;font-size:1.8rem;opacity:.2;transform:translateY(-50%);">🪷</div>
        <span class="sec-en" style="color:var(--hwang,#D4820A);">offering of light</span>
        <h2 id="ind-ttl" style="font-family:var(--font,serif);font-size:clamp(2rem,5vw,3rem);font-weight:900;letter-spacing:.1em;color:var(--ink,#1A120A);margin-top:.3rem;">{ind.title ?? '인등불사'}</h2>
        {ind.subtitle && <p style="font-family:var(--font,serif);font-size:.82rem;letter-spacing:.12em;color:var(--hwang,#D4820A);margin-top:.5rem;font-style:italic;">{ind.subtitle}</p>}
      </div>

      <!-- 인등 종류 그리드 -->
      {hasTypes && (
        <div class="types-grid">
          {ind.types!.map((t, i) => (
            <div class="type-cell" style={`border-top-color:${topColors[i%4]};`}>
              <p class="t-lbl">{t.label}</p>
              <p class="t-amt" style={`color:${colors[i%4]};`}>{t.amount}</p>
              {t.period && <p class="t-period">{t.period}</p>}
            </div>
          ))}
        </div>
      )}

      <!-- 계좌 + 스마트페이 -->
      <div class="pay-wrap">
        <!-- 계좌이체 -->
        <div class="acct-box">
          <h3 class="pay-h3">💳 보시 계좌</h3>
          {ind.bank    && <p class="acct-bank">{ind.bank}</p>}
          {ind.account && <p class="acct-num">{ind.account}</p>}
          {ind.holder  && <p class="acct-holder">예금주 · {ind.holder}</p>}
          {!ind.bank && !ind.account && (
            <p style="font-family:var(--font,serif);font-size:.85rem;color:var(--ink-3,#6B5340);">사찰로 직접 문의해 주세요.</p>
          )}
          <button class="copy-btn" onclick={`copyAcct('${ind.account ?? ''}')`}>
            📋 계좌번호 복사
          </button>
        </div>

        <!-- 스마트페이 -->
        <div class="pay-box">
          <h3 class="pay-h3">📱 간편결제</h3>
          <div style="display:flex;flex-direction:column;gap:.7rem;">
            <button class="btn-kakao" onclick="openPay('kakao')">
              <span>💛</span> 카카오페이로 동참하기
            </button>
            <button class="btn-naver" onclick="openPay('naver')">
              <span>🟢</span> 네이버페이로 동참하기
            </button>
            <button class="btn-toss" onclick="openPay('toss')">
              <span>💙</span> 토스로 동참하기
            </button>
          </div>
        </div>
      </div>

      <!-- 안내 노트 -->
      {ind.note && (
        <div style="max-width:900px;margin:.9rem auto 0;padding:1rem 1.5rem;background:var(--hwang-bg,#FEF3DC);border-left:3px solid var(--hwang,#D4820A);">
          <p style="font-family:var(--font,serif);font-size:.78rem;line-height:1.95;letter-spacing:.04em;color:var(--ink-2,#3D2B1A);">
            💌 {ind.note}
          </p>
        </div>
      )}
    </div>
  </section>
)}

<!-- 결제 선택 모달 -->
<div id="payModal" style="display:none;position:fixed;inset:0;z-index:200;background:rgba(26,18,10,.7);backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:1.5rem;">
  <div style="background:#fff;max-width:420px;width:100%;padding:2.5rem 2rem;position:relative;box-shadow:0 20px 60px rgba(26,18,10,.25);">
    <button onclick="closePayModal()" style="position:absolute;top:1rem;right:1rem;font-size:1.4rem;color:var(--ink-3,#6B5340);cursor:pointer;background:none;border:none;line-height:1;">✕</button>
    <h3 id="pmTitle" style="font-family:var(--font,serif);font-size:1.2rem;font-weight:800;letter-spacing:.08em;color:var(--ink,#1A120A);margin-bottom:.4rem;">카카오페이로 동참하기</h3>
    <p style="font-family:var(--font,serif);font-size:.78rem;color:var(--ink-3,#6B5340);letter-spacing:.06em;margin-bottom:1.5rem;">인등 종류를 선택해주세요</p>
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:.5rem;margin-bottom:1.5rem;">
      <div class="pm-amt on" onclick="selAmt(this,'5000')">삼일등 · 5,000원</div>
      <div class="pm-amt" onclick="selAmt(this,'10000')">칠일등 · 10,000원</div>
      <div class="pm-amt" onclick="selAmt(this,'50000')">백일등 · 50,000원</div>
      <div class="pm-amt" onclick="selAmt(this,'100000')">연간등 · 100,000원</div>
    </div>
    <div style="display:flex;flex-direction:column;gap:.6rem;">
      <button id="pm-kakao" class="btn-kakao" onclick="doPay('kakao')"><span>💛</span> 카카오페이 결제</button>
      <button id="pm-naver" class="btn-naver" style="display:none;" onclick="doPay('naver')"><span>🟢</span> 네이버페이 결제</button>
      <button id="pm-toss"  class="btn-toss"  style="display:none;" onclick="doPay('toss')"><span>💙</span> 토스 결제</button>
    </div>
    <p style="font-family:var(--font,serif);font-size:.72rem;color:var(--ink-3,#6B5340);margin-top:1rem;line-height:1.9;">결제 후 성명·소원을 문자로 보내주세요</p>
  </div>
</div>

<style>
  .types-grid { display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;max-width:900px;margin:0 auto 2rem; }
  @media(min-width:640px) { .types-grid { grid-template-columns:repeat(4,1fr); } }
  .type-cell { background:#fff;text-align:center;padding:1.75rem 1rem;border-top:3px solid var(--dan,#C8372D);box-shadow:0 2px 12px rgba(26,18,10,.07);transition:transform .2s; }
  .type-cell:hover { transform:translateY(-3px); }
  .t-lbl    { font-family:var(--font,serif);font-size:.72rem;letter-spacing:.14em;color:var(--ink-3,#6B5340);margin-bottom:.6rem; }
  .t-amt    { font-family:var(--font,serif);font-size:clamp(1.4rem,3vw,2rem);font-weight:900; }
  .t-period { font-family:var(--font,serif);font-size:.68rem;color:var(--ink-4,#9C7E65);margin-top:.3rem; }

  .pay-wrap { max-width:900px;margin:0 auto;display:grid;grid-template-columns:1fr;gap:1rem; }
  @media(min-width:768px) { .pay-wrap { grid-template-columns:1fr 1fr; } }

  .acct-box { background:#fff;border:1.5px solid rgba(200,55,45,.2);padding:2rem 2.2rem; }
  .pay-box  { background:#fff;border:1.5px solid rgba(43,91,168,.2);padding:2rem 2.2rem; }
  .pay-h3   { font-family:var(--font,serif);font-size:1.1rem;font-weight:800;letter-spacing:.1em;color:var(--ink,#1A120A);margin-bottom:1.1rem; }
  .acct-bank   { font-family:var(--font,serif);font-size:.8rem;letter-spacing:.08em;color:var(--ink-3,#6B5340);margin-bottom:.3rem; }
  .acct-num    { font-family:var(--font,serif);font-size:clamp(1.3rem,3vw,1.7rem);font-weight:900;color:var(--ink,#1A120A);letter-spacing:.06em;margin:.4rem 0;word-break:break-all; }
  .acct-holder { font-family:var(--font,serif);font-size:.8rem;letter-spacing:.14em;color:var(--dan,#C8372D); }

  .copy-btn {
    display:inline-flex;align-items:center;gap:.4rem;margin-top:1.1rem;
    padding:.55rem 1.2rem;background:var(--dan-bg,#FDE8E6);
    border:1.5px solid rgba(200,55,45,.3);
    font-family:var(--font,serif);font-size:.72rem;letter-spacing:.1em;color:var(--dan,#C8372D);
    cursor:pointer;transition:background .2s;
  }
  .copy-btn:hover { background:rgba(200,55,45,.12); }

  .btn-kakao { display:flex;align-items:center;justify-content:center;gap:.7rem;padding:1rem 1.5rem;background:#FEE500;color:#191919;font-family:var(--font,serif);font-size:.9rem;font-weight:700;letter-spacing:.06em;border:none;cursor:pointer;transition:opacity .2s,transform .15s;width:100%; }
  .btn-naver { display:flex;align-items:center;justify-content:center;gap:.7rem;padding:1rem 1.5rem;background:#03C75A;color:#fff;font-family:var(--font,serif);font-size:.9rem;font-weight:700;letter-spacing:.06em;border:none;cursor:pointer;transition:opacity .2s,transform .15s;width:100%; }
  .btn-toss  { display:flex;align-items:center;justify-content:center;gap:.7rem;padding:1rem 1.5rem;background:#0064FF;color:#fff;font-family:var(--font,serif);font-size:.9rem;font-weight:700;letter-spacing:.06em;border:none;cursor:pointer;transition:opacity .2s,transform .15s;width:100%; }
  .btn-kakao:hover,.btn-naver:hover,.btn-toss:hover { opacity:.9;transform:translateY(-1px); }

  .pm-amt {
    padding:.7rem .5rem;text-align:center;
    border:1.5px solid rgba(200,55,45,.2);
    font-family:var(--font,serif);font-size:.82rem;color:var(--ink-2,#3D2B1A);
    cursor:pointer;transition:all .15s;background:#fff;
  }
  .pm-amt:hover,.pm-amt.on { background:var(--dan,#C8372D);color:#fff;border-color:var(--dan,#C8372D); }
</style>

<script>
  let curPay = 'kakao';
  let curAmt = '5000';

  function openPay(type: string) {
    curPay = type;
    const titles: Record<string,string> = {kakao:'카카오페이로 동참하기',naver:'네이버페이로 동참하기',toss:'토스로 동참하기'};
    const el = document.getElementById('pmTitle');
    if (el) el.textContent = titles[type];
    ['pm-kakao','pm-naver','pm-toss'].forEach(id => {
      const btn = document.getElementById(id) as HTMLElement;
      if (btn) btn.style.display = 'none';
    });
    const cur = document.getElementById('pm-'+type) as HTMLElement;
    if (cur) cur.style.display = 'flex';
    const modal = document.getElementById('payModal') as HTMLElement;
    if (modal) { modal.style.display = 'flex'; }
  }
  function closePayModal() {
    const modal = document.getElementById('payModal') as HTMLElement;
    if (modal) modal.style.display = 'none';
  }
  function selAmt(el: HTMLElement, amt: string) {
    curAmt = amt;
    document.querySelectorAll<HTMLElement>('.pm-amt').forEach(a => a.classList.remove('on'));
    el.classList.add('on');
  }
  function doPay(type: string) {
    const labels: Record<string,string> = {kakao:'카카오페이',naver:'네이버페이',toss:'토스'};
    const amts: Record<string,string> = {'5000':'5,000원(삼일등)','10000':'10,000원(칠일등)','50000':'50,000원(백일등)','100000':'100,000원(연간등)'};
    alert(`✨ ${labels[type]} 결제 연동 준비중\n\n선택금액: ${amts[curAmt]}\n\n실제 배포 시 PG사 SDK 연동이 필요합니다.\n지금은 계좌이체를 이용해주세요.`);
    closePayModal();
  }
  function copyAcct(acct: string) {
    navigator.clipboard.writeText(acct.replace(/-/g,''))
      .then(() => alert('✅ 계좌번호 복사 완료!\n\n' + acct))
      .catch(() => alert(acct));
  }

  (window as any).openPay = openPay;
  (window as any).closePayModal = closePayModal;
  (window as any).selAmt = selAmt;
  (window as any).doPay = doPay;
  (window as any).copyAcct = copyAcct;

  document.getElementById('payModal')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('payModal')) closePayModal();
  });
</script>
