---
// IndungSection.astro — 인등불사 + 간편결제 v3
import type { TempleData } from '../../content/config';
interface Props { d: TempleData; }
const { d } = Astro.props;
const ind = d.indung;
const hasTypes = ind?.types && ind.types.length > 0;
const topColors = ['#C8372D','#2B5BA8','#3A7D44','#D4820A'];
const amtColors = ['#C8372D','#2B5BA8','#3A7D44','#D4820A'];
---

{ind && (
  <section id="indung" class="ind-sec" aria-labelledby="ind-ttl">
    <div aria-hidden="true" class="ind-bg-deco"></div>
    <div class="w" style="position:relative;">

      <!-- 인등 헤더 -->
      <div class="ind-header">
        <div aria-hidden="true" class="ind-lotus l">🪷</div>
        <div aria-hidden="true" class="ind-lotus r">🪷</div>
        <span class="sec-en" style="color:#D4820A;">offering of light</span>
        <h2 id="ind-ttl" class="ind-title">{ind.title ?? '인등불사'}</h2>
        {ind.subtitle && <p class="ind-sub">{ind.subtitle}</p>}
      </div>

      <!-- 인등 종류 -->
      {hasTypes && (
        <div class="types-grid">
          {ind.types!.map((t, i) => (
            <div class="type-cell" style={`border-top-color:${topColors[i%4]};`}>
              <p class="t-lbl">{t.label}</p>
              <p class="t-amt" style={`color:${amtColors[i%4]};`}>{t.amount}</p>
              {t.period && <p class="t-period">{t.period}</p>}
            </div>
          ))}
        </div>
      )}

      <!-- 계좌 + 간편결제 -->
      <div class="pay-wrap">
        <!-- 계좌이체 -->
        <div class="acct-box">
          <h3 class="pay-h3">💳 보시 계좌</h3>
          {ind.bank    && <p class="acct-bank">{ind.bank}</p>}
          {ind.account && <p class="acct-num">{ind.account}</p>}
          {ind.holder  && <p class="acct-holder">예금주 · {ind.holder}</p>}
          <button class="copy-btn" onclick={`copyAcct('${ind.account ?? ''}')`}>📋 계좌번호 복사</button>
        </div>

        <!-- 간편결제 -->
        <div class="pay-box">
          <h3 class="pay-h3">📱 간편결제</h3>
          <div style="display:flex;flex-direction:column;gap:.65rem;">
            <button class="btn-kakao" onclick="openPay('kakao')"><span>💛</span> 카카오페이로 동참하기</button>
            <button class="btn-naver" onclick="openPay('naver')"><span>🟢</span> 네이버페이로 동참하기</button>
            <button class="btn-toss"  onclick="openPay('toss')"><span>💙</span> 토스로 동참하기</button>
          </div>
        </div>
      </div>

      {ind.note && (
        <div class="ind-note">
          <p>💌 {ind.note}</p>
        </div>
      )}
    </div>
  </section>
)}

<!-- 결제 모달 — 심플 안내만 -->
<div id="payModal" class="pm-backdrop">
  <div class="pm-box">
    <button onclick="closePayModal()" class="pm-close">✕</button>
    <div style="text-align:center;padding:1rem 0 .5rem;">
      <p style="font-size:2rem;margin-bottom:.7rem;">🙏</p>
      <h3 id="pmTitle" class="pm-title">인등불사 동참 안내</h3>
    </div>
    <div class="pm-msg">
      <p class="pm-line1">결제 연동 준비중입니다.</p>
      <p class="pm-line2">계좌이체를 이용해 주세요.</p>
    </div>
    <div class="pm-acct" id="pmAcct"></div>
    <button onclick="closePayModal()" class="pm-ok">확인</button>
  </div>
</div>

<style>
  .ind-sec { background:var(--bg,#FDFAF4);padding:5.5rem 0 6rem;scroll-margin-top:64px;position:relative;overflow:hidden; }
  .ind-bg-deco {
    position:absolute;inset:0;pointer-events:none;
    background-image:radial-gradient(circle at 10% 20%,rgba(200,55,45,.04) 0%,transparent 50%),
                     radial-gradient(circle at 90% 80%,rgba(43,91,168,.04) 0%,transparent 50%);
  }

  .ind-header {
    text-align:center;padding:3rem 1.4rem 2.5rem;
    background:linear-gradient(135deg,#FEF3DC 0%,#FFFBF2 50%,#FDE8E6 100%);
    border:1.5px solid rgba(212,130,10,.18);margin-bottom:2.5rem;
    position:relative;
  }
  .ind-lotus { position:absolute;top:50%;font-size:1.6rem;opacity:.18;transform:translateY(-50%); }
  .ind-lotus.l { left:1.5rem; }
  .ind-lotus.r { right:1.5rem; }
  .ind-title { font-family:var(--font,serif);font-size:clamp(1.9rem,5vw,3rem);font-weight:900;letter-spacing:.1em;color:#1A120A;margin-top:.3rem; }
  .ind-sub   { font-family:var(--font,serif);font-size:.8rem;letter-spacing:.12em;color:#D4820A;margin-top:.45rem;font-style:italic; }

  /* 인등 그리드 */
  .types-grid { display:grid;grid-template-columns:repeat(2,1fr);gap:.9rem;max-width:900px;margin:0 auto 2rem; }
  @media(min-width:640px) { .types-grid{grid-template-columns:repeat(4,1fr)} }
  .type-cell { background:#fff;text-align:center;padding:1.6rem 1rem;border-top:3px solid #C8372D;box-shadow:0 2px 10px rgba(26,18,10,.06);transition:transform .2s; }
  .type-cell:hover { transform:translateY(-3px); }
  .t-lbl    { font-family:var(--font,serif);font-size:.68rem;letter-spacing:.12em;color:#6B5340;margin-bottom:.55rem;word-break:keep-all; }
  .t-amt    { font-family:var(--font,serif);font-size:clamp(1.3rem,3vw,1.9rem);font-weight:900; }
  .t-period { font-family:var(--font,serif);font-size:.66rem;color:#9C7E65;margin-top:.3rem; }

  /* 계좌+결제 */
  .pay-wrap { max-width:900px;margin:0 auto;display:grid;grid-template-columns:1fr;gap:.9rem; }
  @media(min-width:768px) { .pay-wrap{grid-template-columns:1fr 1fr} }
  .acct-box { background:#fff;border:1.5px solid rgba(200,55,45,.18);padding:1.8rem 2rem; }
  .pay-box  { background:#fff;border:1.5px solid rgba(43,91,168,.18);padding:1.8rem 2rem; }
  .pay-h3   { font-family:var(--font,serif);font-size:1.05rem;font-weight:800;letter-spacing:.1em;color:#1A120A;margin-bottom:1rem; }
  .acct-bank   { font-family:var(--font,serif);font-size:.78rem;color:#6B5340;margin-bottom:.25rem; }
  .acct-num    { font-family:var(--font,serif);font-size:clamp(1.2rem,3vw,1.65rem);font-weight:900;color:#1A120A;letter-spacing:.06em;margin:.35rem 0;word-break:break-all; }
  .acct-holder { font-family:var(--font,serif);font-size:.78rem;letter-spacing:.14em;color:#C8372D; }
  .copy-btn    { display:inline-flex;align-items:center;gap:.35rem;margin-top:1rem;padding:.5rem 1.1rem;background:#FDE8E6;border:1.5px solid rgba(200,55,45,.28);font-family:var(--font,serif);font-size:.7rem;letter-spacing:.1em;color:#C8372D;cursor:pointer;transition:background .2s; }
  .copy-btn:hover { background:rgba(200,55,45,.1); }

  .btn-kakao { display:flex;align-items:center;justify-content:center;gap:.6rem;padding:.9rem 1.4rem;background:#FEE500;color:#191919;font-family:var(--font,serif);font-size:.88rem;font-weight:700;letter-spacing:.04em;border:none;cursor:pointer;transition:opacity .2s,transform .15s;width:100%;white-space:nowrap; }
  .btn-naver { display:flex;align-items:center;justify-content:center;gap:.6rem;padding:.9rem 1.4rem;background:#03C75A;color:#fff;font-family:var(--font,serif);font-size:.88rem;font-weight:700;letter-spacing:.04em;border:none;cursor:pointer;transition:opacity .2s,transform .15s;width:100%;white-space:nowrap; }
  .btn-toss  { display:flex;align-items:center;justify-content:center;gap:.6rem;padding:.9rem 1.4rem;background:#0064FF;color:#fff;font-family:var(--font,serif);font-size:.88rem;font-weight:700;letter-spacing:.04em;border:none;cursor:pointer;transition:opacity .2s,transform .15s;width:100%;white-space:nowrap; }
  .btn-kakao:hover,.btn-naver:hover,.btn-toss:hover { opacity:.88;transform:translateY(-1px); }

  .ind-note { max-width:900px;margin:.8rem auto 0;padding:.9rem 1.4rem;background:#FEF3DC;border-left:3px solid #D4820A; }
  .ind-note p { font-family:var(--font,serif);font-size:.76rem;line-height:1.9;letter-spacing:.04em;color:#3D2B1A;word-break:keep-all; }

  /* 모달 — 심플 */
  .pm-backdrop { display:none;position:fixed;inset:0;z-index:200;background:rgba(26,18,10,.65);backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:1.5rem; }
  .pm-box { background:#fff;max-width:380px;width:100%;padding:2.2rem 1.8rem;position:relative;box-shadow:0 20px 50px rgba(26,18,10,.2);text-align:center; }
  .pm-close { position:absolute;top:.9rem;right:.9rem;font-size:1.2rem;color:#6B5340;cursor:pointer;background:none;border:none;line-height:1; }
  .pm-title { font-family:var(--font,serif);font-size:1.15rem;font-weight:800;letter-spacing:.08em;color:#1A120A;margin-bottom:1.2rem; }
  .pm-msg   { margin:0 0 1.5rem; }
  .pm-line1 { font-family:var(--font,serif);font-size:1rem;font-weight:700;color:#C8372D;letter-spacing:.06em;margin-bottom:.4rem; }
  .pm-line2 { font-family:var(--font,serif);font-size:.9rem;color:#3D2B1A;letter-spacing:.05em; }
  .pm-acct  { font-family:var(--font,serif);font-size:.82rem;color:#6B5340;margin-bottom:1.5rem;line-height:1.9; }
  .pm-ok { width:100%;padding:.9rem;background:#C8372D;color:#fff;font-family:var(--font,serif);font-size:.9rem;font-weight:700;letter-spacing:.12em;border:none;cursor:pointer; }
  .pm-ok:hover { background:#A82820; }
</style>

<script>
  function openPay(_type: string) {
    const acct = document.querySelector<HTMLElement>('.acct-num')?.textContent ?? '';
    const bank = document.querySelector<HTMLElement>('.acct-bank')?.textContent ?? '';
    const holder = document.querySelector<HTMLElement>('.acct-holder')?.textContent ?? '';
    const acctEl = document.getElementById('pmAcct');
    if (acctEl && (acct||bank)) {
      acctEl.innerHTML = `<strong>${bank}</strong><br>${acct}<br>${holder}`;
    }
    const modal = document.getElementById('payModal') as HTMLElement;
    if (modal) { modal.style.display = 'flex'; }
  }
  function closePayModal() {
    const modal = document.getElementById('payModal') as HTMLElement;
    if (modal) modal.style.display = 'none';
  }
  function copyAcct(acct: string) {
    navigator.clipboard.writeText(acct.replace(/-/g,''))
      .then(() => alert('✅ 계좌번호 복사!\n\n' + acct))
      .catch(() => alert(acct));
  }
  (window as any).openPay = openPay;
  (window as any).closePayModal = closePayModal;
  (window as any).copyAcct = copyAcct;
  document.getElementById('payModal')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('payModal')) closePayModal();
  });
</script>
