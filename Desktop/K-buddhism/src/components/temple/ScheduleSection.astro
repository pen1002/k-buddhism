---
// src/components/temple/ScheduleSection.astro — 법회 일정 v2
import type { TempleData } from '../../content/config';
interface Props { d: TempleData; }
const { d } = Astro.props;
const evs = d.events ?? [];
const icons = ['🙏','🪷','⛺','🕯','🌕','🍲','📿','✨'];
const colors = ['var(--dan,#C8372D)','var(--chung,#2B5BA8)','var(--nok,#3A7D44)','var(--hwang,#D4820A)'];
---

{evs.length > 0 && (
  <section id="schedule" style="background:var(--bg2,#F5EFE0);padding:5.5rem 0 6rem;scroll-margin-top:64px;" aria-labelledby="sch-ttl">
    <div class="w">
      <span class="sec-en" style="color:var(--dan,#C8372D);">ceremony &amp; schedule</span>
      <h2 id="sch-ttl" class="sec-h2" style="font-size:clamp(2rem,4.5vw,3rem);margin-top:.3rem;">법회 · 행사 일정</h2>
      <div class="dc-bar"><span class="b2"></span><span class="b1"></span><span class="b4"></span><span class="b3"></span></div>

      <div class="sch-grid">
        {evs.map((ev, i) => (
          <div class="sch-card" style={`border-bottom-color:${colors[i%4]};`}>
            <div class="sch-ico">{ev.emoji ?? icons[i%8]}</div>
            <h3 class="sch-h3">{ev.name}</h3>
            <div class="sch-meta">
              {(ev.schedule||ev.time) && <p>📅 {ev.schedule ?? ev.time}</p>}
              {ev.schedule && ev.time  && <p>⏰ {ev.time}</p>}
              {ev.location             && <p>📍 {ev.location}</p>}
            </div>
            {ev.note && <p class="sch-note">{ev.note}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .sch-grid { display:grid;gap:1rem;grid-template-columns:1fr; }
  @media(min-width:640px)  { .sch-grid { grid-template-columns:repeat(2,1fr); } }
  @media(min-width:1024px) { .sch-grid { grid-template-columns:repeat(4,1fr); } }

  .sch-card {
    background:#fff;padding:1.6rem 1.5rem;
    border-bottom:3px solid var(--dan,#C8372D);
    box-shadow:0 2px 10px rgba(26,18,10,.06);
    transition:transform .2s,box-shadow .2s;
  }
  .sch-card:hover { transform:translateY(-3px);box-shadow:0 8px 20px rgba(26,18,10,.1); }
  .sch-ico  { font-size:1.6rem;margin-bottom:.75rem; }
  .sch-h3   { font-family:var(--font,serif);font-size:1.05rem;font-weight:700;letter-spacing:.05em;color:var(--ink,#1A120A);margin-bottom:.6rem;line-height:1.5; }
  .sch-meta { font-family:var(--font,serif);font-size:.77rem;color:var(--ink-3,#6B5340);line-height:1.85;letter-spacing:.04em; }
  .sch-meta p { margin:0; }
  .sch-note {
    margin-top:.65rem;padding-top:.6rem;
    border-top:1px solid rgba(26,18,10,.07);
    font-family:var(--font,serif);font-size:.72rem;color:var(--dan,#C8372D);line-height:1.75;
  }
</style>
