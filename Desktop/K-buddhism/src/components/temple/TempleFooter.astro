---
// src/components/temple/TempleFooter.astro — 밝은 단청 배경 v2
import { parseContact, parseAddress } from '../../lib/cloudinary';
import type { TempleData } from '../../content/config';
interface Props { d: TempleData; }
const { d } = Astro.props;
const addr = parseAddress(d.address);
const cont = parseContact(d.contact);
const links = [
  { label:'공지사항',   href:'#events'   },
  { label:'사찰소개',   href:'#intro'    },
  { label:'사찰갤러리', href:'#gallery'  },
  { label:'법회일정',   href:'#schedule' },
  { label:'인등불사',   href:'#indung'   },
  { label:'오시는 길',  href:'#visit'    },
];
---

<!-- ── FOOTER — 밝은 단청 배경 ── -->
<footer style="background:#F5EFE0;border-top:4px solid transparent;border-image:linear-gradient(to right,#C8372D,#F0A830,#3A7D44,#2B5BA8) 1;">
  <div class="w">
    <div class="ft-grid">

      <!-- 사찰 정보 -->
      <div class="ft-wide">
        <div style="display:flex;align-items:center;gap:.7rem;margin-bottom:.9rem;">
          <span style="font-size:1.8rem;">🪷</span>
          <div>
            <p style="font-family:var(--font,serif);font-size:1.1rem;font-weight:700;color:#1A120A;letter-spacing:.07em;">{d.name}</p>
            {d.name_hanja && <p style="font-family:var(--font,serif);font-size:.6rem;letter-spacing:.4em;color:#C8372D;margin-top:2px;">{d.name_hanja}</p>}
          </div>
        </div>
        <div style="font-family:var(--font,serif);font-size:.75rem;line-height:2;letter-spacing:.04em;color:#6B5340;">
          <p>{d.sect}</p>
          {addr.full   && <p>{addr.full}</p>}
          {addr.postal && <p>(우) {addr.postal}</p>}
        </div>
        <div style="display:flex;gap:1.25rem;margin-top:.9rem;flex-wrap:wrap;">
          {cont.mobile && <a href={`tel:${cont.mobile.replace(/-/g,'')}`} style="font-family:var(--font,serif);font-size:.74rem;letter-spacing:.08em;color:#C8372D;font-weight:700;">📱 {cont.mobile}</a>}
          {cont.phone  && <a href={`tel:${cont.phone.replace(/-/g,'')}`}  style="font-family:var(--font,serif);font-size:.74rem;letter-spacing:.08em;color:#2B5BA8;font-weight:700;">☎️ {cont.phone}</a>}
          {cont.email  && <a href={`mailto:${cont.email}`}               style="font-family:var(--font,serif);font-size:.74rem;letter-spacing:.08em;color:#3A7D44;">✉️ {cont.email}</a>}
        </div>
      </div>

      <!-- 바로가기 -->
      <div>
        <h3 style="font-family:var(--font,serif);font-size:.8rem;font-weight:800;letter-spacing:.2em;color:#C8372D;margin-bottom:1rem;border-bottom:1.5px solid rgba(200,55,45,.2);padding-bottom:.4rem;">바로가기</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:.5rem;">
          {links.map(l => (
            <li><a href={l.href} class="ft-a">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- 관련 링크 -->
      <div>
        <h3 style="font-family:var(--font,serif);font-size:.8rem;font-weight:800;letter-spacing:.2em;color:#2B5BA8;margin-bottom:1rem;border-bottom:1.5px solid rgba(43,91,168,.2);padding-bottom:.4rem;">관련 링크</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:.5rem;">
          {d.blog_url    && <li><a href={d.blog_url}    target="_blank" rel="noopener noreferrer" class="ft-a">네이버 블로그 ↗</a></li>}
          {d.youtube_url && <li><a href={d.youtube_url} target="_blank" rel="noopener noreferrer" class="ft-a">유튜브 채널 ↗</a></li>}
          {addr.map_url  && <li><a href={addr.map_url}  target="_blank" rel="noopener noreferrer" class="ft-a">네이버 지도 ↗</a></li>}
          <li><a href="/" class="ft-a">K-Buddhism Hub ↗</a></li>
        </ul>
      </div>
    </div>

    <!-- 카피라이트 -->
    <div style="border-top:1px solid rgba(26,18,10,.1);padding:1rem 0;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;">
      <p style="font-family:var(--font,serif);font-size:.68rem;letter-spacing:.08em;color:#9C7E65;">
        © {new Date().getFullYear()} {d.name}. All rights reserved.
      </p>
      <p style="font-family:var(--font,serif);font-size:.64rem;letter-spacing:.08em;color:#9C7E65;">
        K-Buddhism · Powered by Astro
      </p>
    </div>
  </div>
</footer>

<!-- FAB -->
<a href="#hero"
  style="position:fixed;bottom:1.25rem;right:1.1rem;z-index:40;width:40px;height:40px;display:flex;align-items:center;justify-content:center;background:#C8372D;color:#fff;font-size:.9rem;box-shadow:0 4px 16px rgba(200,55,45,.4);transition:background .2s,transform .2s;"
  aria-label="맨 위로"
  onmouseenter="this.style.transform='translateY(-2px)'"
  onmouseleave="this.style.transform='translateY(0)'"
>↑</a>

<style>
  .ft-grid {
    display:grid;gap:2.5rem;grid-template-columns:1fr;
    padding:3rem 0 2rem;
  }
  @media(min-width:640px)  { .ft-grid{grid-template-columns:repeat(2,1fr)} }
  @media(min-width:1024px) { .ft-grid{grid-template-columns:2fr 1fr 1fr} }
  .ft-wide {}
  @media(min-width:640px)  { .ft-wide{grid-column:span 2} }
  @media(min-width:1024px) { .ft-wide{grid-column:span 1} }
  .ft-a {
    font-family:var(--font,serif);font-size:.76rem;
    letter-spacing:.06em;color:#6B5340;
    transition:color .2s;
  }
  .ft-a:hover { color:#C8372D; }
</style>
