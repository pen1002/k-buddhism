---
// src/layouts/CustomLayout.astro
// ✅ 선암사형 커스텀 레이아웃
// 새 사찰 추가 시: seonamsa.html의 내용을 복붙하거나
// data.name, data.contact 등을 바인딩해서 재사용 가능

interface Props {
  data: any
}
const { data: d } = Astro.props

// 동적 바인딩 가능한 값들
const title   = d.title   ?? '선암사'
const phone   = d.contact?.phone ?? '061-754-5247'
const address = d.address?.full  ?? '전라남도 순천시 승주읍 선암사길 450'
---
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>{title} — 조계산 천년 고찰, 한국불교 태고종</title>
<meta name="description" content="전남 순천 조계산 선암사. 승선교, 홍매화, 천년의 숨결이 살아있는 한국불교 태고종 본찰."/>
<meta property="og:title" content="선암사 仙巖寺"/>
<meta property="og:description" content="조계산 깊은 숲 속 천년 고찰 선암사 — 승선교·홍매화·원통전"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;600;700;900&family=IM+Fell+English:ital@0;1&family=Nanum+Myeongjo:wght@400;700;800&display=swap" rel="stylesheet"/>
<style>
:root{
  --moss:    #3A5235;
  --moss2:   #2A3D27;
  --earth:   #7C5539;
  --plum:    #8C3B5A;
  --cream:   #F6F1E8;
  --parch:   #EDE5D4;
  --ink:     #1C1A16;
  --mid:     #5A5043;
  --muted:   #9A9080;
  --line:    rgba(90,80,67,.12);
  --gold:    #C49A3C;
  --font-k:  'Noto Serif KR', 'Nanum Myeongjo', serif;
  --font-e:  'IM Fell English', Georgia, serif;
  --nav-h:   68px;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--cream);color:var(--ink);font-family:var(--font-k);-webkit-font-smoothing:antialiased;overflow-x:hidden;}
a{text-decoration:none;color:inherit;}
img{display:block;object-fit:cover;}

/* ══ GRAIN TEXTURE OVERLAY ══ */
body::before{
  content:'';pointer-events:none;
  position:fixed;inset:0;z-index:9999;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  opacity:.35;mix-blend-mode:multiply;
}

/* ══ NAV ══ */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  height:var(--nav-h);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 3rem;
  background:rgba(246,241,232,.95);
  border-bottom:1px solid var(--line);
  backdrop-filter:blur(20px);
  transition:box-shadow .4s;
}
.nav.scrolled{box-shadow:0 4px 40px rgba(60,50,40,.1);}
.nav-brand{display:flex;align-items:center;gap:.9rem;}
.nav-emblem{
  width:40px;height:40px;border-radius:50%;
  background:var(--moss);
  display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;color:#fff;
  box-shadow:0 2px 12px rgba(58,82,53,.35);
}
.brand-ko{font-family:var(--font-k);font-size:1rem;font-weight:700;letter-spacing:.12em;color:var(--ink);}
.brand-en{font-family:var(--font-e);font-size:.62rem;letter-spacing:.4em;color:var(--moss);margin-top:1px;font-style:italic;}
.nav-links{display:none;align-items:center;gap:.3rem;}
.nav-a{
  font-family:var(--font-k);font-size:.75rem;letter-spacing:.1em;
  color:var(--mid);padding:.4rem .9rem;
  position:relative;transition:color .2s;
}
.nav-a::after{
  content:'';position:absolute;bottom:0;left:.9rem;right:100%;
  height:1px;background:var(--moss);transition:right .25s;
}
.nav-a:hover,
.nav-a.on{color:var(--moss);}
.nav-a:hover::after,
.nav-a.on::after{right:.9rem;}
.nav-cta{
  font-family:var(--font-k);font-size:.72rem;letter-spacing:.1em;
  padding:.45rem 1.2rem;
  background:var(--moss);color:#fff;
  transition:background .2s;
}
.nav-cta:hover{background:var(--moss2);}
.ham{display:flex;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:.3rem;}
.hbar{width:22px;height:1.5px;background:var(--ink);}

/* ══ HERO — 조계산 숲 분위기 ══ */
.hero{
  position:relative;
  min-height:100vh;
  display:grid;
  grid-template-columns:1fr 1fr;
  overflow:hidden;
  margin-top:var(--nav-h);
}
/* 왼쪽 텍스트 패널 */
.hero-left{
  position:relative;z-index:2;
  display:flex;flex-direction:column;justify-content:center;
  padding:5rem 4rem 5rem 5rem;
  background:var(--moss2);
  overflow:hidden;
}
.hero-left::before{
  content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(
    45deg,transparent,transparent 30px,
    rgba(255,255,255,.012) 30px,rgba(255,255,255,.012) 31px
  );
}
.hero-left::after{
  content:'仙巖寺';
  position:absolute;right:-1rem;bottom:3rem;
  font-family:var(--font-k);font-size:10rem;font-weight:900;
  color:rgba(255,255,255,.04);letter-spacing:.1em;
  line-height:1;white-space:nowrap;
  pointer-events:none;
}
.hero-season{
  display:inline-flex;align-items:center;gap:.6rem;
  font-family:var(--font-e);font-size:.65rem;letter-spacing:.35em;
  color:rgba(196,154,60,.85);text-transform:uppercase;
  border:1px solid rgba(196,154,60,.3);
  padding:.4rem 1rem;margin-bottom:2rem;
  width:fit-content;
}
.hero-title{
  font-family:var(--font-k);
  font-size:clamp(3rem,6vw,5.5rem);
  font-weight:900;color:#fff;
  letter-spacing:.06em;line-height:1;
  margin-bottom:.6rem;
  position:relative;z-index:1;
}
.hero-hanja{
  font-family:var(--font-e);
  font-size:clamp(1rem,2vw,1.4rem);
  font-weight:400;font-style:italic;
  letter-spacing:.5em;
  color:rgba(196,154,60,.7);
  margin-bottom:1.4rem;
}
.hero-divider{
  width:48px;height:1px;
  background:linear-gradient(to right,rgba(196,154,60,.8),transparent);
  margin-bottom:1.4rem;
}
.hero-slogan{
  font-family:var(--font-k);font-size:.84rem;
  color:rgba(255,255,255,.6);line-height:2.1;
  max-width:320px;margin-bottom:2.5rem;
}
.hero-btns{display:flex;gap:.8rem;flex-wrap:wrap;}
.btn-solid{
  font-family:var(--font-k);font-size:.75rem;letter-spacing:.1em;
  padding:.65rem 1.6rem;
  background:var(--gold);color:var(--ink);
  font-weight:700;transition:opacity .2s;
}
.btn-solid:hover{opacity:.85;}
.btn-outline{
  font-family:var(--font-k);font-size:.75rem;letter-spacing:.1em;
  padding:.65rem 1.6rem;
  border:1px solid rgba(255,255,255,.3);color:rgba(255,255,255,.8);
  transition:border-color .2s,color .2s;
}
.btn-outline:hover{border-color:#fff;color:#fff;}

/* 오른쪽 이미지 패널 */
.hero-right{
  position:relative;overflow:hidden;
  min-height:600px;
}
.hero-right img{
  width:100%;height:100%;
  object-fit:cover;
  transition:transform 8s ease;
}
.hero-right:hover img{transform:scale(1.04);}
.hero-right-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to right,rgba(42,61,39,.6) 0%,transparent 40%),
             linear-gradient(to top,rgba(42,61,39,.5) 0%,transparent 40%);
}
/* 계절 배지 */
.hero-badge-float{
  position:absolute;bottom:2rem;right:2rem;
  background:rgba(246,241,232,.92);
  padding:.8rem 1.2rem;
  text-align:center;
  backdrop-filter:blur(8px);
}
.hbf-num{font-family:var(--font-e);font-size:1.8rem;font-weight:400;color:var(--moss);line-height:1;}
.hbf-lbl{font-family:var(--font-k);font-size:.62rem;color:var(--mid);letter-spacing:.08em;margin-top:.2rem;}

/* ══ TICKER ══ */
.ticker{
  background:var(--moss);
  padding:.7rem 0;overflow:hidden;
}
.ticker-track{
  display:flex;gap:0;white-space:nowrap;
  animation:tick 28s linear infinite;
}
@keyframes tick{from{transform:translateX(0);}to{transform:translateX(-50%);}}
.ti{font-family:var(--font-k);font-size:.72rem;letter-spacing:.12em;color:rgba(255,255,255,.8);padding:0 1.5rem;}
.td{color:rgba(196,154,60,.7);padding:0 .2rem;}

/* ══ SECTION BASE ══ */
.sec{padding:5.5rem 5rem;max-width:1300px;margin:0 auto;}
.sec-bg{padding:5.5rem 5rem;}
.lbl{font-family:var(--font-e);font-size:.65rem;letter-spacing:.35em;color:var(--moss);text-transform:uppercase;margin-bottom:.6rem;display:block;font-style:italic;}
.sec-ttl{font-family:var(--font-k);font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;line-height:1.25;margin-bottom:.6rem;}
.sec-desc{font-family:var(--font-k);font-size:.82rem;color:var(--muted);line-height:1.85;}
.sec-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:3rem;gap:1rem;flex-wrap:wrap;}
.more-link{font-family:var(--font-e);font-size:.65rem;letter-spacing:.2em;color:var(--moss);font-style:italic;border-bottom:1px solid var(--moss);padding-bottom:.1rem;white-space:nowrap;}

/* ══ HIGHLIGHT STATS ══ */
.stats-bar{
  background:var(--moss2);
  display:grid;grid-template-columns:repeat(4,1fr);
}
.stat-item{
  padding:2.4rem 2rem;text-align:center;
  border-right:1px solid rgba(255,255,255,.07);
  transition:background .2s;
}
.stat-item:last-child{border-right:none;}
.stat-item:hover{background:rgba(255,255,255,.04);}
.stat-num{font-family:var(--font-e);font-size:2.4rem;font-weight:400;color:var(--gold);line-height:1;}
.stat-unit{font-family:var(--font-e);font-size:1rem;color:rgba(196,154,60,.6);}
.stat-lbl{font-family:var(--font-k);font-size:.7rem;color:rgba(255,255,255,.45);margin-top:.5rem;letter-spacing:.08em;}

/* ══ EVENTS ══ */
.ev-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem;}
.ev-card{
  background:#fff;border:1px solid var(--line);
  overflow:hidden;cursor:pointer;
  transition:transform .25s,box-shadow .25s,border-color .25s;
}
.ev-card:hover{transform:translateY(-5px);box-shadow:0 16px 40px rgba(60,50,40,.1);border-color:var(--moss);}
.ev-thumb{height:150px;display:flex;align-items:center;justify-content:center;font-size:2.8rem;position:relative;overflow:hidden;}
.ev-thumb-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.3),transparent);}
.ev-body{padding:1.3rem;}
.ev-tag{font-family:var(--font-e);font-size:.58rem;letter-spacing:.2em;color:var(--moss);font-style:italic;}
.ev-name{font-family:var(--font-k);font-size:.88rem;font-weight:700;margin:.4rem 0;}
.ev-sub{font-family:var(--font-k);font-size:.73rem;color:var(--muted);line-height:1.7;}
.ev-price{
  font-family:var(--font-e);font-size:.75rem;letter-spacing:.1em;color:var(--earth);
  border-top:1px solid var(--line);padding-top:.6rem;margin-top:.7rem;
}

/* ══ SPLIT PROMO ══ */
.promo{
  display:grid;grid-template-columns:1fr 1fr;
  min-height:480px;
  overflow:hidden;
}
.promo-img{position:relative;overflow:hidden;}
.promo-img img{width:100%;height:100%;object-fit:cover;transition:transform 6s ease;}
.promo-img:hover img{transform:scale(1.05);}
.promo-img-overlay{
  position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(42,61,39,.5),rgba(58,82,53,.2));
}
.promo-quote{
  position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;
  padding:2.5rem;
}
.pq-text{
  font-family:var(--font-e);font-size:1.4rem;font-weight:400;font-style:italic;
  color:#fff;line-height:1.5;text-shadow:0 2px 12px rgba(0,0,0,.4);
}
.pq-src{font-family:var(--font-k);font-size:.7rem;color:rgba(255,255,255,.55);margin-top:.6rem;letter-spacing:.15em;}

.promo-info{
  background:var(--parch);
  display:flex;flex-direction:column;justify-content:center;
  padding:4rem;gap:1.8rem;
}
.promo-item{display:flex;gap:1.2rem;align-items:flex-start;padding-bottom:1.6rem;border-bottom:1px solid var(--line);}
.promo-item:last-child{border-bottom:none;padding-bottom:0;}
.pi-icon{font-size:1.6rem;flex-shrink:0;margin-top:.1rem;}
.pi-name{font-family:var(--font-k);font-size:.88rem;font-weight:700;margin-bottom:.3rem;}
.pi-sub{font-family:var(--font-k);font-size:.75rem;color:var(--muted);line-height:1.7;}
.pi-tag{
  display:inline-block;font-family:var(--font-e);font-size:.58rem;letter-spacing:.15em;
  color:var(--moss);border:1px solid var(--moss);padding:.2rem .6rem;
  margin-top:.5rem;font-style:italic;
}

/* ══ INTRO (사찰소개) ══ */
.intro-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;}
.intro-img-wrap{position:relative;}
.intro-main-img{width:100%;height:420px;object-fit:cover;}
.intro-sub-img{
  position:absolute;bottom:-2rem;right:-2rem;
  width:200px;height:150px;object-fit:cover;
  border:4px solid var(--cream);
  box-shadow:0 8px 32px rgba(60,50,40,.2);
}
.info-table{margin-top:2rem;display:flex;flex-direction:column;gap:0;}
.info-row{display:flex;border-bottom:1px solid var(--line);padding:.7rem 0;}
.info-key{font-family:var(--font-e);font-size:.62rem;letter-spacing:.2em;color:var(--moss);min-width:72px;flex-shrink:0;font-style:italic;padding-top:.05rem;}
.info-val{font-family:var(--font-k);font-size:.82rem;color:var(--ink);line-height:1.7;}

/* ══ HERITAGE (보물/문화재) ══ */
.heritage-bg{background:var(--parch);}
.heritage-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.5rem;max-width:1300px;margin:0 auto;padding:0 5rem 5.5rem;}
.hc{
  position:relative;overflow:hidden;cursor:pointer;
  background:#fff;
  transition:transform .3s,box-shadow .3s;
}
.hc:hover{transform:translateY(-6px);box-shadow:0 20px 50px rgba(60,50,40,.15);}
.hc-img{height:240px;width:100%;object-fit:cover;transition:transform .5s;}
.hc:hover .hc-img{transform:scale(1.06);}
.hc-body{padding:1.5rem;}
.hc-num{font-family:var(--font-e);font-size:.6rem;letter-spacing:.25em;color:var(--gold);font-style:italic;margin-bottom:.4rem;}
.hc-name{font-family:var(--font-k);font-size:.95rem;font-weight:700;margin-bottom:.4rem;}
.hc-desc{font-family:var(--font-k);font-size:.75rem;color:var(--muted);line-height:1.7;}
.hc-badge{
  display:inline-block;margin-top:.8rem;
  font-family:var(--font-e);font-size:.58rem;letter-spacing:.15em;
  color:var(--moss);border:1px solid var(--moss);padding:.2rem .7rem;font-style:italic;
}

/* ══ HISTORY ══ */
.history-section{background:var(--ink);position:relative;overflow:hidden;}
.history-section::before{
  content:'千年';position:absolute;right:-2rem;top:50%;transform:translateY(-50%);
  font-family:var(--font-k);font-size:22rem;font-weight:900;
  color:rgba(255,255,255,.025);line-height:1;pointer-events:none;
}
.history-inner{max-width:1300px;margin:0 auto;padding:5.5rem 5rem;}
.h-timeline{position:relative;margin-top:3rem;}
.h-timeline::before{content:'';position:absolute;left:110px;top:0;bottom:0;width:1px;background:rgba(255,255,255,.08);}
.h-item{
  display:flex;gap:2rem;align-items:flex-start;
  padding:1.6rem 0;border-bottom:1px solid rgba(255,255,255,.05);
}
.h-item:last-child{border-bottom:none;}
.h-yr{
  font-family:var(--font-e);font-size:1rem;font-weight:400;
  color:var(--gold);min-width:100px;text-align:right;flex-shrink:0;font-style:italic;
}
.h-dot{
  width:8px;height:8px;border-radius:50%;flex-shrink:0;
  background:var(--moss);border:2px solid var(--ink);
  margin-top:.35rem;position:relative;z-index:1;
}
.h-evt{font-family:var(--font-k);font-size:.84rem;color:rgba(255,255,255,.65);line-height:1.85;}
.h-evt .sub{display:block;font-size:.75rem;color:rgba(255,255,255,.35);margin-top:.3rem;}

/* ══ GALLERY ══ */
.gallery-grid{
  display:grid;
  grid-template-columns:2fr 1fr 1fr;
  grid-template-rows:auto auto;
  gap:.8rem;
}
.g{overflow:hidden;position:relative;cursor:pointer;}
.g img{width:100%;height:100%;object-fit:cover;transition:transform .5s;}
.g:hover img{transform:scale(1.05);}
.g-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(26,26,22,.7) 0%,transparent 50%);
  opacity:0;transition:opacity .3s;
}
.g:hover .g-overlay{opacity:1;}
.g-cap{
  position:absolute;bottom:0;left:0;right:0;
  padding:1.2rem;transform:translateY(8px);transition:transform .3s;
  opacity:0;
}
.g:hover .g-cap{opacity:1;transform:translateY(0);}
.g-cap .name{font-family:var(--font-k);font-size:.82rem;font-weight:700;color:#fff;}
.g-cap .sub{font-family:var(--font-k);font-size:.7rem;color:rgba(255,255,255,.65);margin-top:.15rem;}

/* ══ INDUNG ══ */
.indung-grid{display:grid;grid-template-columns:400px 1fr;gap:2.5rem;align-items:start;}
.indung-panel{
  background:var(--moss2);
  padding:2.8rem;color:#fff;position:sticky;top:calc(var(--nav-h) + 2rem);
}
.ind-badge{
  display:inline-block;font-family:var(--font-e);font-size:.58rem;letter-spacing:.25em;
  border:1px solid rgba(196,154,60,.45);color:rgba(196,154,60,.85);
  padding:.3rem .9rem;margin-bottom:1.4rem;font-style:italic;
}
.ind-title{font-family:var(--font-k);font-size:1.4rem;font-weight:700;line-height:1.4;margin-bottom:1rem;}
.ind-desc{font-family:var(--font-k);font-size:.78rem;color:rgba(255,255,255,.6);line-height:1.9;margin-bottom:1.6rem;}
.ind-price-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:.7rem 0;border-bottom:1px solid rgba(255,255,255,.08);
}
.ind-price-row .k{font-family:var(--font-k);font-size:.8rem;color:rgba(255,255,255,.75);}
.ind-price-row .v{font-family:var(--font-e);font-size:1rem;color:var(--gold);}
.bank-box{
  background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);
  padding:1rem 1.2rem;margin:1.2rem 0;
}
.bank-ttl{font-family:var(--font-e);font-size:.58rem;letter-spacing:.2em;color:rgba(196,154,60,.75);margin-bottom:.7rem;font-style:italic;}
.bank-row{display:flex;justify-content:space-between;padding:.25rem 0;}
.bank-row .bk{font-family:var(--font-k);font-size:.7rem;color:rgba(255,255,255,.4);}
.bank-row .bv{font-family:var(--font-k);font-size:.75rem;color:rgba(255,255,255,.85);font-weight:700;}
.bank-note{font-family:var(--font-k);font-size:.68rem;color:rgba(255,255,255,.4);margin-top:.6rem;line-height:1.6;}
.ind-btn{
  display:block;text-align:center;margin-top:.7rem;
  font-family:var(--font-k);font-size:.75rem;letter-spacing:.1em;
  padding:.7rem;transition:background .2s;border:1px solid transparent;
}
.ind-btn.primary{background:var(--gold);color:var(--ink);font-weight:700;}
.ind-btn.primary:hover{background:#b3892e;}
.ind-btn.ghost{border-color:rgba(255,255,255,.25);color:rgba(255,255,255,.8);}
.ind-btn.ghost:hover{background:rgba(255,255,255,.08);}

.ind-cards{display:flex;flex-direction:column;gap:1rem;}
.ind-card{
  display:flex;gap:1.2rem;align-items:flex-start;padding:1.4rem;
  border:1px solid var(--line);background:#fff;
  transition:border-color .25s,transform .25s;
}
.ind-card:hover{border-color:var(--moss);transform:translateX(4px);}
.ic-ico{font-size:1.8rem;flex-shrink:0;}
.ic-name{font-family:var(--font-k);font-size:.9rem;font-weight:700;margin-bottom:.4rem;}
.ic-sub{font-family:var(--font-k);font-size:.75rem;color:var(--muted);line-height:1.7;}
.ic-badge{
  display:inline-block;margin-top:.6rem;
  font-family:var(--font-e);font-size:.58rem;letter-spacing:.15em;
  color:var(--moss);border:1px solid var(--moss);padding:.2rem .6rem;font-style:italic;
}

/* ══ BRAND STORY ══ */
.brand-story{
  height:420px;position:relative;overflow:hidden;
  display:flex;align-items:center;justify-content:center;
  background:var(--moss2);
}
.bs-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.3;}
.bs-veil{
  position:absolute;inset:0;
  background:linear-gradient(to bottom,rgba(42,61,39,.7),rgba(42,61,39,.9));
}
.bs-content{position:relative;z-index:1;text-align:center;}
.bs-en{
  font-family:var(--font-e);font-size:clamp(1.6rem,5vw,3.8rem);
  font-weight:400;font-style:italic;letter-spacing:.08em;
  color:rgba(255,255,255,.85);line-height:1.2;margin-bottom:.8rem;
}
.bs-ko{font-family:var(--font-k);font-size:.82rem;color:rgba(255,255,255,.4);letter-spacing:.25em;}
.bs-line{width:60px;height:1px;background:var(--gold);margin:.8rem auto;}

/* ══ VISIT ══ */
.visit-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;}
.map-frame{height:340px;border:1px solid var(--line);overflow:hidden;}
.map-frame iframe{width:100%;height:100%;border:none;}
.v-list{list-style:none;display:flex;flex-direction:column;gap:1rem;}
.v-row{display:flex;gap:1rem;align-items:flex-start;padding-bottom:1rem;border-bottom:1px solid var(--line);}
.v-row:last-child{border-bottom:none;}
.v-key{font-family:var(--font-e);font-size:.6rem;letter-spacing:.2em;color:var(--moss);min-width:64px;flex-shrink:0;font-style:italic;padding-top:.1rem;}
.v-val{font-family:var(--font-k);font-size:.82rem;line-height:1.7;}

/* ══ FOOTER ══ */
footer{background:var(--ink);padding:4rem 5rem 2.5rem;color:rgba(255,255,255,.5);}
.ft-top{
  display:grid;grid-template-columns:220px 1fr 1fr 1fr;
  gap:2.5rem;margin-bottom:2.5rem;
  padding-bottom:2.5rem;border-bottom:1px solid rgba(255,255,255,.07);
}
.ft-logo .ko{font-family:var(--font-k);font-size:1.1rem;font-weight:700;color:#fff;letter-spacing:.1em;}
.ft-logo .en{font-family:var(--font-e);font-size:.62rem;letter-spacing:.3em;color:rgba(196,154,60,.7);margin-top:.3rem;font-style:italic;}
.ft-logo .tg{font-family:var(--font-k);font-size:.7rem;color:rgba(255,255,255,.3);margin-top:.7rem;line-height:1.7;}
.fc h4{font-family:var(--font-e);font-size:.6rem;letter-spacing:.25em;color:rgba(255,255,255,.35);text-transform:uppercase;margin-bottom:1rem;font-style:italic;}
.fc ul{list-style:none;display:flex;flex-direction:column;gap:.5rem;}
.fc a{font-family:var(--font-k);font-size:.72rem;color:rgba(255,255,255,.45);transition:color .2s;}
.fc a:hover{color:rgba(196,154,60,.8);}
.ft-bot{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;}
.ft-bot p{font-family:var(--font-k);font-size:.68rem;color:rgba(255,255,255,.2);}

/* ══ MOB MENU ══ */
.mob{
  display:none;position:fixed;inset:0;z-index:190;
  background:var(--cream);flex-direction:column;
  padding:calc(var(--nav-h) + 1.5rem) 2rem 2rem;
  overflow-y:auto;gap:.3rem;
}
.mob-a{
  font-family:var(--font-k);font-size:1.3rem;font-weight:700;
  letter-spacing:.04em;color:var(--ink);padding:.9rem .5rem;
  border-bottom:1px solid var(--line);
}
.mob-close{position:fixed;top:1.2rem;right:1.5rem;z-index:300;font-size:1.4rem;background:none;border:none;cursor:pointer;}

/* ══ FADE-IN ══ */
.fi{opacity:0;transform:translateY(24px);transition:opacity .7s ease,transform .7s ease;}
.fi.vis{opacity:1;transform:none;}
.fi.d1{transition-delay:.1s;}
.fi.d2{transition-delay:.2s;}
.fi.d3{transition-delay:.3s;}
.fi.d4{transition-delay:.4s;}
.fi.d5{transition-delay:.5s;}

/* ══ RESPONSIVE ══ */
@media(min-width:860px){.nav-links{display:flex;}.ham{display:none;}}
@media(max-width:1100px){
  .hero{grid-template-columns:1fr;}
  .hero-right{display:none;}
  .heritage-grid{grid-template-columns:1fr 1fr;}
  .gallery-grid{grid-template-columns:1fr 1fr;}
  .indung-grid{grid-template-columns:1fr;}
  .promo{grid-template-columns:1fr;}
}
@media(max-width:860px){
  .nav-links,.nav-cta{display:none;}
  .ham{display:flex;}
  .sec{padding:3.5rem 1.5rem;}
  .sec-bg{padding:3.5rem 1.5rem;}
  .history-inner{padding:3.5rem 1.5rem;}
  .hero-left{padding:3.5rem 1.5rem;}
  .stats-bar{grid-template-columns:1fr 1fr;}
  .ev-grid{grid-template-columns:1fr 1fr;}
  .intro-grid{grid-template-columns:1fr;}
  .visit-grid{grid-template-columns:1fr;}
  .ft-top{grid-template-columns:1fr 1fr;}
  footer{padding:3rem 1.5rem 2rem;}
  .heritage-grid{padding:0 1.5rem 3.5rem;}
  .h-timeline::before{left:80px;}
  .h-yr{min-width:70px;}
}
@media(max-width:500px){
  .ev-grid{grid-template-columns:1fr;}
  .heritage-grid{grid-template-columns:1fr;}
  .ft-top{grid-template-columns:1fr;}
  .gallery-grid{grid-template-columns:1fr;}
  .stats-bar{grid-template-columns:1fr 1fr;}
}
</style>
