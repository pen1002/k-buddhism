<script>
function openMob(){document.getElementById('mob').style.display='flex';}
function closeMob(){document.getElementById('mob').style.display='none';}

/* 스크롤 fade-in */
const io=new IntersectionObserver(es=>{
  es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');});
},{threshold:.08});
document.querySelectorAll('.fi').forEach(el=>io.observe(el));

/* NAV 활성 */
const nas=document.querySelectorAll('.nav-a');
const obs=new IntersectionObserver(es=>{
  es.forEach(e=>{
    if(e.isIntersecting){
      const id='#'+e.target.id;
      nas.forEach(a=>a.classList.toggle('on',a.getAttribute('href')===id));
    }
  });
},{rootMargin:'-40% 0px -55% 0px'});
['events','intro','heritage','history','gallery','indung','visit'].forEach(id=>{
  const el=document.getElementById(id);if(el)obs.observe(el);
});

/* NAV 그림자 */
window.addEventListener('scroll',()=>{
  document.getElementById('mainNav').classList.toggle('scrolled',window.scrollY>60);
},{passive:true});
</script>
