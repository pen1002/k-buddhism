---
// src/pages/[slug].astro
import { getCollection, getEntry } from 'astro:content';
import HeroSection       from '../components/temple/HeroSection.astro';
import EventsSection     from '../components/temple/EventsSection.astro';
import IntroSection      from '../components/temple/IntroSection.astro';
import GallerySection    from '../components/temple/GallerySection.astro';
import ScheduleSection   from '../components/temple/ScheduleSection.astro';
import IndungSection     from '../components/temple/IndungSection.astro';
import DirectionsSection from '../components/temple/DirectionsSection.astro';
import TempleFooter      from '../components/temple/TempleFooter.astro';
import '../styles/temple.css';

export async function getStaticPaths() {
  const all = await getCollection('temples', e => e.data.active !== false);
  return all.map(e => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry('temples', slug as string);
if (!entry) return Astro.redirect('/404');

const { Content } = await entry.render();
const d = entry.data as any;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>{d.title}</title>
  <meta name="description" content={d.description ?? d.slogan} />
  <meta property="og:title"       content={d.title} />
  <meta property="og:description" content={d.description ?? d.slogan} />
  <meta property="og:type"        content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;600;700;900&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ── 고정 NAV ── -->
  <nav id="main-nav" style="position:fixed;top:0;left:0;right:0;z-index:80;height:60px;display:flex;align-items:center;padding:0 1.4rem;background:rgba(253,250,244,.96);border-bottom:2px solid #C8372D;box-shadow:0 2px 20px rgba(200,55,45,.12);backdrop-filter:blur(12px);transition:box-shadow .3s;">
    <div style="display:flex;align-items:center;gap:.6rem;flex-shrink:0;">
      <span style="font-size:1.5rem;">🪷</span>
      <div>
        <div style="font-family:var(--font,serif);font-size:1.05rem;font-weight:700;color:var(--ink,#1A120A);letter-spacing:.06em;">{d.name}</div>
        {d.name_hanja && <div style="font-family:var(--font,serif);font-size:.58rem;letter-spacing:.4em;color:#C8372D;margin-top:1px;">{d.name_hanja}</div>}
      </div>
    </div>
    <!-- 데스크탑 메뉴 -->
    <div id="nav-links" style="display:none;align-items:center;gap:0;margin-left:auto;">
      <a href="#events"   class="nav-a">행사안내</a>
      <a href="#intro"    class="nav-a">사찰소개</a>
      <a href="#gallery"  class="nav-a">사찰갤러리</a>
      <a href="#schedule" class="nav-a">법회일정</a>
      <a href="#indung"   class="nav-a">인등불사</a>
      <a href="#visit"    class="nav-a">오시는 길</a>
      {d.contact && (
        <a href={`tel:${typeof d.contact==='string' ? d.contact.split(',')[0].replace(/\s/g,'') : ''}`}
          style="margin-left:1rem;padding:.45rem 1.1rem;background:#C8372D;color:#fff;font-family:var(--font,serif);font-size:.72rem;letter-spacing:.1em;border-radius:2px;">
          📞 전화 문의
        </a>
      )}
    </div>
    <!-- 햄버거 -->
    <div id="ham-btn" style="display:flex;flex-direction:column;gap:5px;margin-left:auto;cursor:pointer;padding:.4rem;" onclick="toggleMob()">
      <span style="display:block;width:22px;height:2px;background:#C8372D;"></span>
      <span style="display:block;width:22px;height:2px;background:#C8372D;"></span>
      <span style="display:block;width:22px;height:2px;background:#C8372D;"></span>
    </div>
  </nav>

  <!-- 모바일 메뉴 -->
  <div id="mob-menu" style="display:none;position:fixed;inset:0;z-index:79;background:rgba(253,250,244,.98);padding:80px 2rem 2rem;flex-direction:column;gap:1rem;">
    <a href="#events"   onclick="closeMob()" style="font-family:var(--font,serif);font-size:1.25rem;letter-spacing:.08em;color:var(--ink-2,#3D2B1A);padding:.65rem 0;border-bottom:1px solid rgba(200,55,45,.12);">🎏 행사안내</a>
    <a href="#intro"    onclick="closeMob()" style="font-family:var(--font,serif);font-size:1.25rem;letter-spacing:.08em;color:var(--ink-2,#3D2B1A);padding:.65rem 0;border-bottom:1px solid rgba(200,55,45,.12);">🏯 사찰소개</a>
    <a href="#gallery"  onclick="closeMob()" style="font-family:var(--font,serif);font-size:1.25rem;letter-spacing:.08em;color:var(--ink-2,#3D2B1A);padding:.65rem 0;border-bottom:1px solid rgba(200,55,45,.12);">🖼 사찰갤러리</a>
    <a href="#schedule" onclick="closeMob()" style="font-family:var(--font,serif);font-size:1.25rem;letter-spacing:.08em;color:var(--ink-2,#3D2B1A);padding:.65rem 0;border-bottom:1px solid rgba(200,55,45,.12);">📅 법회일정</a>
    <a href="#indung"   onclick="closeMob()" style="font-family:var(--font,serif);font-size:1.25rem;letter-spacing:.08em;color:var(--ink-2,#3D2B1A);padding:.65rem 0;border-bottom:1px solid rgba(200,55,45,.12);">🕯 인등불사</a>
    <a href="#visit"    onclick="closeMob()" style="font-family:var(--font,serif);font-size:1.25rem;letter-spacing:.08em;color:var(--ink-2,#3D2B1A);padding:.65rem 0;border-bottom:1px solid rgba(200,55,45,.12);">🗺 오시는 길</a>
  </div>

  <!-- 본문 (margin-top: 60px — NAV 높이만큼) -->
  <main style="margin-top:60px;">
    <HeroSection       d={d} />
    <div class="dc-div"></div>
    <EventsSection     d={d} />
    <div class="dc-div"></div>
    <IntroSection      d={d} Content={Content} />
    <div class="dc-div"></div>
    <GallerySection    d={d} />
    <div class="dc-div"></div>
    <ScheduleSection   d={d} />
    <div class="dc-div"></div>
    <IndungSection     d={d} />
    <div class="dc-div"></div>
    <DirectionsSection d={d} />
  </main>

  <TempleFooter d={d} />

</body>
</html>

<style>
  .nav-a {
    padding:.48rem .9rem;
    font-family:var(--font,serif);font-size:.72rem;letter-spacing:.1em;
    color:var(--ink-3,#6B5340);transition:color .2s;
    border-bottom:2px solid transparent;white-space:nowrap;
  }
  .nav-a:hover,.nav-a.on { color:#C8372D;border-bottom-color:#C8372D; }
  @media(min-width:768px) {
    #nav-links  { display:flex !important; }
    #ham-btn    { display:none !important; }
  }
</style>

<script>
  function toggleMob() {
    const m = document.getElementById('mob-menu')!;
    m.style.display = m.style.display === 'none' ? 'flex' : 'none';
    m.style.flexDirection = 'column';
  }
  function closeMob() {
    document.getElementById('mob-menu')!.style.display = 'none';
  }

  // 스크롤 NAV 활성
  const secs = ['events','intro','gallery','schedule','indung','visit'];
  const navAs = document.querySelectorAll<HTMLAnchorElement>('.nav-a');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting)
        navAs.forEach(a => a.classList.toggle('on', a.getAttribute('href') === '#'+e.target.id));
    });
  }, { rootMargin: '-40% 0px -55% 0px' });
  secs.forEach(id => { const el = document.getElementById(id); if (el) obs.observe(el); });

  // 스크롤 그림자
  window.addEventListener('scroll', () => {
    const n = document.getElementById('main-nav')!;
    n.style.boxShadow = window.scrollY > 80
      ? '0 4px 28px rgba(200,55,45,.18)'
      : '0 2px 20px rgba(200,55,45,.12)';
  }, { passive: true });

  (window as any).toggleMob = toggleMob;
  (window as any).closeMob  = closeMob;
</script>
