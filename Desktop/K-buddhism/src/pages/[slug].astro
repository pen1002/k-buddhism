---
// src/pages/[slug].astro
import { getCollection } from 'astro:content'
import TemplateLayout from '../layouts/TemplateLayout.astro'
import CustomLayout   from '../layouts/CustomLayout.astro'

export async function getStaticPaths() {
  const temples = await getCollection('temples')
  return temples
    .filter(t => t.data.active !== false)
    .map(t => ({
      params: { slug: t.slug },
      props:  { entry: t },
    }))
}

const { entry } = Astro.props
const d = entry.data
const { Content } = await entry.render()
---

{d.layout === 'custom'
  ? <CustomLayout data={d}><Content /></CustomLayout>
  : <TemplateLayout data={d}><Content /></TemplateLayout>
}
