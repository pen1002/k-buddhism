---
// src/pages/[slug].astro — v3 햄버거 2배 + 빠른 스크롤
import { getCollection, getEntry } from 'astro:content';
import HeroSection       from '../components/temple/HeroSection.astro';
import EventsSection     from '../components/temple/EventsSection.astro';
import IntroSection      from '../components/temple/IntroSection.astro';
import GallerySection    from '../components/temple/GallerySection.astro';
import IndungSection     from '../components/temple/IndungSection.astro';
import DirectionsSection from '../components/temple/DirectionsSection.astro';
import TempleFooter      from '../components/temple/TempleFooter.astro';
import '../styles/temple.css';

export async function getStaticPaths() {
  const all = await getCollection('temples', e => e.data.active !== false);
  return all.map(e => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry('temples', slug as string);
if (!entry) return Astro.redirect('/404');

const { Content } = await entry.render();
const d = entry.data as any;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>{d.title}</title>
  <meta name="description" content={d.description ?? d.slogan} />
  <meta property="og:title"       content={d.title} />
  <meta property="og:description" content={d.description ?? d.slogan} />
  <meta property="og:type"        content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;600;700;900&display=swap" rel="stylesheet" />
  <style>
    /* 부드러운 스크롤 — 빠른 속도 */
    html { scroll-behavior: smooth; }
    @media (prefers-reduced-motion: no-preference) {
      html { scroll-behavior: smooth; }
      /* 스크롤 속도 최적화 */
      * { scroll-margin-top: 64px; }
    }
  </style>
</head>
<body data-theme={`t${d.ui_type ?? 1}`}>
```

  <!-- ── 고정 NAV ── -->
  <nav id="main-nav" class="mnav">
    <a href="#hero" style="display:flex;align-items:center;gap:.55rem;flex-shrink:0;text-decoration:none;">
      <span style="font-size:1.4rem;">🪷</span>
      <div>
        <div class="nav-name">{d.name}</div>
        {d.name_hanja && <div class="nav-hanja">{d.name_hanja}</div>}
      </div>
    </a>

    <!-- 데스크탑 메뉴 -->
    <div id="nav-links" class="nav-links">
      <a href="#events"  class="nav-a">공지·행사</a>
      <a href="#intro"   class="nav-a">사찰소개</a>
      <a href="#gallery" class="nav-a">사찰갤러리</a>
      <a href="#indung"  class="nav-a">인등불사</a>
      <a href="#visit"   class="nav-a">오시는 길</a>
      {d.contact && (
        <a href={`tel:${typeof d.contact==='string' ? d.contact.split(',')[0].trim().replace(/\s/g,'') : ''}`}
          class="nav-call">📞 전화 문의</a>
      )}
    </div>

    <!-- 햄버거 — 2배 크기 -->
    <button id="ham-btn" class="ham-btn" onclick="toggleMob()" aria-label="메뉴 열기">
      <span class="hbar"></span>
      <span class="hbar"></span>
      <span class="hbar"></span>
    </button>
  </nav>

  <!-- 모바일 메뉴 — 큰 글씨 -->
  <div id="mob-menu" class="mob-menu">
    <button onclick="closeMob()" class="mob-close" aria-label="닫기">✕</button>
    <a href="#events"  onclick="closeMob()" class="mob-a">🎏 공지·행사</a>
    <a href="#intro"   onclick="closeMob()" class="mob-a">🏯 사찰소개</a>
    <a href="#gallery" onclick="closeMob()" class="mob-a">🖼 사찰갤러리</a>
    <a href="#indung"  onclick="closeMob()" class="mob-a">🕯 인등불사</a>
    <a href="#visit"   onclick="closeMob()" class="mob-a">🗺 오시는 길</a>
    {d.contact && (
      <a href={`tel:${typeof d.contact==='string' ? d.contact.split(',')[0].trim().replace(/\s/g,'') : ''}`}
        class="mob-a mob-call">📞 전화 문의</a>
    )}
  </div>

  <!-- 본문 -->
  <main style="margin-top:60px;">
    <HeroSection       d={d} />
    <div class="dc-div"></div>
    <EventsSection     d={d} />
    <div class="dc-div"></div>
    <IntroSection      d={d} Content={Content} />
    <div class="dc-div"></div>
    <GallerySection    d={d} />
    <div class="dc-div"></div>
    <IndungSection     d={d} />
    <div class="dc-div"></div>
    <DirectionsSection d={d} />
  </main>

  <TempleFooter d={d} />

</body>
</html>

<style>
  /* ── 고정 NAV ── */
  .mnav {
    position:fixed;top:0;left:0;right:0;z-index:80;
    height:60px;display:flex;align-items:center;
    padding:0 1.2rem;
    background:rgba(253,250,244,.96);
    border-bottom:2px solid #C8372D;
    box-shadow:0 2px 18px rgba(200,55,45,.11);
    backdrop-filter:blur(12px);
    transition:box-shadow .3s;
  }
  .nav-name  { font-family:var(--font,serif);font-size:1rem;font-weight:700;color:#1A120A;letter-spacing:.06em; }
  .nav-hanja { font-family:var(--font,serif);font-size:.56rem;letter-spacing:.4em;color:#C8372D;margin-top:1px; }

  .nav-links { display:none;align-items:center;gap:0;margin-left:auto; }
  .nav-a {
    padding:.46rem .88rem;
    font-family:var(--font,serif);font-size:.7rem;letter-spacing:.1em;
    color:#6B5340;transition:color .2s;
    border-bottom:2px solid transparent;white-space:nowrap;
  }
  .nav-a:hover,.nav-a.on { color:#C8372D;border-bottom-color:#C8372D; }
  .nav-call {
    margin-left:.8rem;padding:.42rem 1rem;
    background:#C8372D;color:#fff;
    font-family:var(--font,serif);font-size:.7rem;letter-spacing:.1em;
    border-radius:2px;white-space:nowrap;
  }
  .nav-call:hover { background:#A82820; }

  /* 햄버거 — 2배 크기 */
  .ham-btn {
    display:flex;flex-direction:column;justify-content:center;gap:7px;
    margin-left:auto;
    cursor:pointer;
    padding:.6rem .5rem;
    background:none;border:none;
  }
  .hbar {
    display:block;
    width:30px;   /* 기존 22px → 30px */
    height:3px;   /* 기존 2px → 3px */
    background:#C8372D;
    border-radius:2px;
    transition:transform .25s,opacity .25s;
  }

  /* 모바일 메뉴 */
  .mob-menu {
    display:none;
    position:fixed;inset:0;z-index:79;
    background:rgba(253,250,244,.98);
    padding:80px 2.5rem 2rem;
    flex-direction:column;gap:.4rem;
    overflow-y:auto;
  }
  .mob-close {
    position:absolute;top:1rem;right:1.5rem;
    font-size:1.8rem;color:#6B5340;
    cursor:pointer;background:none;border:none;line-height:1;
  }
  .mob-a {
    font-family:var(--font,serif);
    font-size:1.5rem;   /* 기존보다 훨씬 크게 */
    font-weight:700;
    letter-spacing:.06em;color:#3D2B1A;
    padding:.85rem .5rem;
    border-bottom:1.5px solid rgba(200,55,45,.1);
    transition:color .2s;
  }
  .mob-a:hover { color:#C8372D; }
  .mob-call {
    margin-top:.6rem;
    background:#C8372D;color:#fff;
    text-align:center;padding:1rem;border:none;
  }

  @media(min-width:768px) {
    .nav-links { display:flex !important; }
    .ham-btn   { display:none !important; }
  }
</style>

<script>
  // 빠른 스크롤 — CSS scroll-behavior:smooth + scrollIntoView
  function smoothTo(id: string) {
    const el = document.getElementById(id);
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // 모든 anchor 클릭 가로채서 빠른 스크롤 적용
  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const id = a.getAttribute('href')?.slice(1);
      if (id) { e.preventDefault(); smoothTo(id); }
    });
  });

  function toggleMob() {
    const m = document.getElementById('mob-menu') as HTMLElement;
    const isOpen = m.style.display === 'flex';
    m.style.display = isOpen ? 'none' : 'flex';
    if (!isOpen) m.style.flexDirection = 'column';
  }
  function closeMob() {
    (document.getElementById('mob-menu') as HTMLElement).style.display = 'none';
  }

  // 스크롤 NAV 활성 (교차 감지)
  const secs = ['events','intro','gallery','indung','visit'];
  const navAs = document.querySelectorAll<HTMLAnchorElement>('.nav-a');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const href = '#' + e.target.id;
        navAs.forEach(a => a.classList.toggle('on', a.getAttribute('href') === href));
      }
    });
  }, { rootMargin:'-40% 0px -55% 0px' });
  secs.forEach(id => { const el = document.getElementById(id); if(el) obs.observe(el); });

  // 스크롤 그림자
  window.addEventListener('scroll', () => {
    const n = document.getElementById('main-nav') as HTMLElement;
    if (n) n.style.boxShadow = window.scrollY > 60
      ? '0 4px 26px rgba(200,55,45,.16)'
      : '0 2px 18px rgba(200,55,45,.11)';
  }, { passive:true });

  (window as any).toggleMob = toggleMob;
  (window as any).closeMob  = closeMob;
</script>
