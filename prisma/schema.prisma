// ============================================================
// 108사찰 Multi-tenant Database Schema
// - 모든 데이터에 templeId 포함 → 엄격한 데이터 격리
// - NextAuth.js 인증 테이블 포함
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- 사찰 (Temple) ----
model Temple {
  id          String   @id @default(cuid())
  code        String   @unique            // URL 식별자: munsusa, borimsa
  name        String                      // 표시명: 문수사
  nameEn      String?                     // English: Munsusa
  description String?  @db.Text
  logoUrl     String?
  heroImageUrl String?
  address     String?
  phone       String?
  email       String?

  // 테마 설정
  primaryColor   String  @default("#8B2500")  // 메인 색상
  secondaryColor String  @default("#C5A572")  // 보조 색상
  fontFamily     String  @default("Pretendard")

  // 도메인 설정
  customDomain   String?  @unique           // 커스텀 도메인: munsusa.com
  subdomain      String?  @unique           // 서브도메인: munsusa (→ munsusa.k-buddhism.com)

  // 사찰 정보
  denomination   String?                    // 종단: 대한불교조계종
  foundedYear    Int?
  abbotName      String?                    // 주지스님

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  posts       Post[]
  galleries   Gallery[]
  events      Event[]
  members     TempleMember[]
  domainMaps  DomainMap[]

  @@index([code])
  @@index([customDomain])
  @@index([subdomain])
}

// ---- 도메인 매핑 (Vercel KV 캐시 소스) ----
model DomainMap {
  id       String  @id @default(cuid())
  domain   String  @unique               // 전체 도메인: munsusa.com, xn--z92bu3hg5a.com
  templeId String
  temple   Temple  @relation(fields: [templeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([domain])
}

// ---- 게시글/법문 (Post) ----
model Post {
  id        String   @id @default(cuid())
  templeId  String
  temple    Temple   @relation(fields: [templeId], references: [id], onDelete: Cascade)

  title     String
  slug      String
  content   String   @db.Text
  excerpt   String?  @db.Text
  coverImage String?

  category  PostCategory @default(NOTICE)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  authorId    String?
  author      User?     @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templeId, slug])
  @@index([templeId, category])
  @@index([templeId, isPublished])
}

enum PostCategory {
  NOTICE        // 공지사항
  DHARMA_TALK   // 법문
  NEWS          // 소식
  COLUMN        // 칼럼
}

// ---- 갤러리 (Gallery) ----
model Gallery {
  id        String   @id @default(cuid())
  templeId  String
  temple    Temple   @relation(fields: [templeId], references: [id], onDelete: Cascade)

  title     String
  description String? @db.Text
  images    GalleryImage[]

  isPublished Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templeId])
}

model GalleryImage {
  id        String  @id @default(cuid())
  galleryId String
  gallery   Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  url       String
  alt       String?
  width     Int?
  height    Int?
  order     Int     @default(0)

  @@index([galleryId])
}

// ---- 행사/법회 (Event) ----
model Event {
  id        String   @id @default(cuid())
  templeId  String
  temple    Temple   @relation(fields: [templeId], references: [id], onDelete: Cascade)

  title     String
  description String? @db.Text
  location  String?
  startDate DateTime
  endDate   DateTime?
  isRecurring Boolean @default(false)

  isPublished Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templeId, startDate])
}

// ============================================================
// NextAuth.js 인증 테이블 + RBAC
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(MEMBER)

  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  templeMembers TempleMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  SUPER_ADMIN    // 전체 관리자
  TEMPLE_ADMIN   // 사찰 관리자
  EDITOR         // 편집자
  MEMBER         // 일반 회원
}

// ---- 사찰-회원 연결 (RBAC 핵심) ----
model TempleMember {
  id       String          @id @default(cuid())
  userId   String
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  templeId String
  temple   Temple          @relation(fields: [templeId], references: [id], onDelete: Cascade)
  role     TempleMemberRole @default(VIEWER)

  createdAt DateTime @default(now())

  @@unique([userId, templeId])
  @@index([templeId])
}

enum TempleMemberRole {
  ADMIN    // 사찰 관리자 (수정 권한)
  EDITOR   // 편집자 (게시글만)
  VIEWER   // 조회만
}

// ---- NextAuth 표준 테이블 ----
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
