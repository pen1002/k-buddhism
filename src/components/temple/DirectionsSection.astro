---
// src/components/temple/DirectionsSection.astro — 오시는 길 v2
import { parseContact, parseAddress } from '../../lib/cloudinary';
import type { TempleData } from '../../content/config';
interface Props { d: TempleData; }
const { d } = Astro.props;
const addr = parseAddress(d.address);
const cont = parseContact(d.contact);
---

<section id="visit" style="background:var(--bg2,#F5EFE0);padding:5.5rem 0 6rem;scroll-margin-top:64px;" aria-labelledby="vis-ttl">
  <div class="w">
    <span class="sec-en" style="color:var(--nok,#3A7D44);">directions &amp; contact</span>
    <h2 id="vis-ttl" class="sec-h2" style="font-size:clamp(2rem,4.5vw,3rem);margin-top:.3rem;">오시는 길 · 연락처</h2>
    <div class="dc-bar"><span class="b3"></span><span class="b4"></span><span class="b1"></span><span class="b2"></span></div>

    <div class="vis-grid">
      <!-- 주소 -->
      <div class="addr-box">
        <h3 style="font-family:var(--font,serif);font-size:1.1rem;font-weight:800;letter-spacing:.1em;color:var(--nok,#3A7D44);margin-bottom:1.25rem;">📍 주소</h3>
        <div style="display:flex;gap:1rem;align-items:flex-start;margin-bottom:1.75rem;">
          <div>
            <p style="font-family:var(--font,serif);font-size:1rem;letter-spacing:.05em;line-height:1.75;color:var(--ink-2,#3D2B1A);">{addr.full ?? (typeof d.address==='string' ? d.address : '주소 정보 없음')}</p>
            {addr.postal && <p style="font-family:var(--font,serif);font-size:.75rem;color:var(--ink-4,#9C7E65);margin-top:.25rem;">(우) {addr.postal}</p>}
          </div>
        </div>
        {addr.map_url && (
          <a href={addr.map_url} target="_blank" rel="noopener noreferrer"
            style="display:inline-flex;align-items:center;gap:.5rem;padding:.7rem 1.5rem;background:var(--nok,#3A7D44);color:#fff;font-family:var(--font,serif);font-size:.78rem;letter-spacing:.12em;transition:background .2s;">
            🗺 네이버지도에서 보기 ↗
          </a>
        )}
      </div>

      <!-- 연락처 -->
      <div class="cont-grid">
        {cont.mobile && (
          <a href={`tel:${cont.mobile.replace(/-/g,'')}`} class="cc cc1">
            <span class="cc-ico">📱</span>
            <div><p class="cc-lbl">휴대전화</p><p class="cc-val">{cont.mobile}</p></div>
          </a>
        )}
        {cont.phone && (
          <a href={`tel:${cont.phone.replace(/-/g,'')}`} class="cc cc2">
            <span class="cc-ico">☎️</span>
            <div><p class="cc-lbl">대표전화</p><p class="cc-val">{cont.phone}</p></div>
          </a>
        )}
        {cont.email && (
          <a href={`mailto:${cont.email}`} class="cc cc3" style="grid-column:span 2;">
            <span class="cc-ico">✉️</span>
            <div><p class="cc-lbl">이메일</p><p class="cc-val" style="word-break:break-all;">{cont.email}</p></div>
          </a>
        )}
        {d.blog_url && (
          <a href={d.blog_url} target="_blank" rel="noopener noreferrer" class="cc cc4" style="grid-column:span 2;">
            <span class="cc-ico">📝</span>
            <div><p class="cc-lbl">네이버 블로그</p><p class="cc-val">바로가기 ↗</p></div>
          </a>
        )}
        {!cont.mobile && !cont.phone && typeof d.contact==='string' && (
          <div class="cc cc1" style="grid-column:span 2;">
            <span class="cc-ico">📞</span>
            <div><p class="cc-lbl">연락처</p><p class="cc-val">{d.contact}</p></div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .vis-grid { display:grid;gap:2rem;grid-template-columns:1fr; }
  @media(min-width:1024px) { .vis-grid { grid-template-columns:repeat(2,1fr);gap:3rem; } }

  .addr-box { background:#fff;padding:2rem 2.2rem;border-top:4px solid var(--nok,#3A7D44);box-shadow:0 2px 12px rgba(26,18,10,.06); }
  .cont-grid { display:grid;grid-template-columns:repeat(2,1fr);gap:.7rem; }

  .cc {
    display:flex;align-items:center;gap:.75rem;
    background:#fff;padding:1.1rem 1.15rem;
    border-left:3px solid var(--dan,#C8372D);
    box-shadow:0 2px 8px rgba(26,18,10,.05);
    transition:transform .2s,box-shadow .2s;
  }
  .cc:hover { transform:translateY(-2px);box-shadow:0 6px 18px rgba(26,18,10,.1); }
  .cc2 { border-left-color:var(--chung,#2B5BA8); }
  .cc3 { border-left-color:var(--nok,#3A7D44); }
  .cc4 { border-left-color:var(--hwang,#D4820A); }
  .cc-ico { font-size:1.35rem;flex-shrink:0; }
  .cc-lbl { font-family:var(--font,serif);font-size:.62rem;letter-spacing:.16em;color:var(--ink-4,#9C7E65);margin-bottom:.15rem; }
  .cc-val { font-family:var(--font,serif);font-size:.9rem;color:var(--ink,#1A120A);letter-spacing:.03em; }
</style>
