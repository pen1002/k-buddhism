---
// src/components/temple/HeroSection.astro — v3 한 줄 이름 + 밝은 오버레이
import { hero as heroUrl, blur as blurUrl } from '../../lib/cloudinary';
import type { TempleData } from '../../content/config';
interface Props { d: TempleData; }
const { d } = Astro.props;
const heroFull = d.hero_image ? heroUrl(d.hero_image) : '';
const heroBlur = d.hero_image ? blurUrl(d.hero_image) : '';
const heritage = (d as any).heritage;
---

<section id="hero" style="position:relative;width:100%;height:100svh;min-height:580px;max-height:920px;overflow:hidden;display:flex;align-items:flex-end;background:#1A0A06;">

  <!-- 단청 상단 컬러 바 -->
  <div aria-hidden="true" style="position:absolute;top:0;left:0;right:0;z-index:5;height:6px;background:linear-gradient(to right,#C8372D,#F0A830,#56A863,#4A7DC4,#F0A830,#C8372D);"></div>

  <!-- 히어로 이미지 -->
  {heroBlur && <img src={heroBlur} alt="" aria-hidden="true" style="position:absolute;inset:0;z-index:0;width:100%;height:100%;object-fit:cover;transform:scale(1.08);" onerror="this.style.display='none'" />}
  {heroFull && <img src={heroFull} alt={`${d.name} 전경`} fetchpriority="high" loading="eager" decoding="async" style="position:absolute;inset:0;z-index:1;width:100%;height:100%;object-fit:cover;transition:transform 10s ease;" onerror="this.style.display='none'" />}

  <!-- 오버레이 — 사진 밝기 최대한 유지, 텍스트 가독성만 확보 -->
  <div aria-hidden="true" style="position:absolute;inset:0;z-index:2;background:linear-gradient(170deg,rgba(0,0,0,.04) 0%,rgba(0,0,0,.04) 40%,rgba(0,0,0,.38) 75%,rgba(0,0,0,.62) 100%);"></div>
  <div aria-hidden="true" style="position:absolute;bottom:0;left:0;right:0;z-index:2;height:28%;background:linear-gradient(to top,rgba(0,0,0,.55) 0%,transparent 100%);"></div>

  <!-- 단청 코너 장식 -->
  <div aria-hidden="true" style="position:absolute;top:20px;right:20px;z-index:5;width:64px;height:64px;opacity:.45;">
    <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
      <rect x="0" y="0" width="100" height="100" fill="none" stroke="rgba(240,168,48,.7)" stroke-width="2.5"/>
      <rect x="8" y="8" width="84" height="84" fill="none" stroke="rgba(200,55,45,.5)" stroke-width="1.5"/>
      <circle cx="50" cy="50" r="28" fill="none" stroke="rgba(58,125,68,.6)" stroke-width="1.5"/>
    </svg>
  </div>

  <!-- 텍스트 영역 z:10 -->
  <div style="position:relative;z-index:10;width:100%;max-width:1280px;margin:0 auto;padding:0 1.4rem 4.5rem;">
    <div style="max-width:820px;">

      <!-- 소속 배지 -->
      <span style="display:inline-block;margin-bottom:1rem;padding:.2rem .9rem;background:rgba(200,55,45,.88);font-family:var(--font,serif);font-size:.68rem;letter-spacing:.18em;color:#fff;animation:hfd .6s .1s both;">{d.sect}</span>

      <!-- 사찰명 — 한 줄 배치 -->
      <div style="animation:hfd .9s .2s both;">
        <h1 style="font-family:var(--font,serif);font-size:clamp(2.6rem,7vw,5.5rem);font-weight:900;color:#fff;line-height:1.05;letter-spacing:.06em;text-shadow:0 2px 0 rgba(0,0,0,.85),0 4px 20px rgba(0,0,0,.7);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
          {d.name}
        </h1>
        {d.name_hanja && (
          <p style="font-family:var(--font,serif);font-size:clamp(.8rem,1.8vw,1rem);letter-spacing:.45em;color:#F0A830;margin-top:.4rem;">{d.name_hanja}</p>
        )}
      </div>

      <!-- 슬로건 -->
      <p style="font-family:var(--font,serif);font-size:clamp(.82rem,1.7vw,1rem);color:rgba(255,255,255,.88);margin-top:1rem;letter-spacing:.05em;font-style:italic;line-height:1.85;animation:hfd .9s .45s both;word-break:keep-all;max-width:620px;">"{d.slogan}"</p>

      <!-- 정보 배지 -->
      <div style="display:flex;flex-wrap:wrap;gap:.4rem;margin-top:1.2rem;animation:hfd .9s .6s both;">
        {d.founded     && <span class="hbadge">{d.founded}</span>}
        {d.main_buddha && <span class="hbadge">주불 · {d.main_buddha}</span>}
        {d.monk        && <span class="hbadge">{d.monk_title ?? '주지'} · {d.monk}</span>}
        {heritage      && <span class="hbadge" style="background:rgba(212,130,10,.75);border-color:rgba(240,168,48,.5);">{heritage}</span>}
      </div>
    </div>
  </div>

  <!-- 스크롤 힌트 -->
  <div style="position:absolute;bottom:1.8rem;left:50%;transform:translateX(-50%);z-index:10;display:flex;flex-direction:column;align-items:center;gap:5px;animation:bob 2.2s ease-in-out infinite;pointer-events:none;" aria-hidden="true">
    <div style="width:1px;height:40px;background:linear-gradient(to bottom,transparent,rgba(240,168,48,.6));"></div>
    <span style="font-family:var(--font,serif);font-size:8px;letter-spacing:.3em;color:rgba(240,168,48,.55);text-transform:uppercase;">Scroll</span>
  </div>
</section>

<style>
  @keyframes hfd { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:none} }
  @keyframes bob  { 0%,100%{transform:translateX(-50%) translateY(0);opacity:.6} 50%{transform:translateX(-50%) translateY(8px);opacity:1} }
  .hbadge {
    padding:.22rem .85rem;
    background:rgba(255,255,255,.12);
    border:1px solid rgba(255,255,255,.28);
    font-family:var(--font,serif);font-size:.68rem;letter-spacing:.1em;
    color:rgba(255,255,255,.92);white-space:nowrap;
  }
  /* 모바일: 사찰명 줄바꿈 허용 */
  @media(max-width:480px) {
    h1 { white-space:normal !important; font-size:clamp(2.2rem,9vw,3.2rem) !important; }
  }
</style>
