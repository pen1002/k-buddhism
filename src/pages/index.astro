---
// src/pages/index.astro — Temple Hub 목록
import { getCollection } from 'astro:content';
import '../styles/temple.css';

const temples = await getCollection('temples', e => e.data.active !== false);
temples.sort((a, b) => (a.data.order_num ?? 99) - (b.data.order_num ?? 99));

// 지역별 그룹
const byRegion: Record<string, typeof temples> = {};
temples.forEach(t => {
  const r = t.data.region ?? '기타';
  if (!byRegion[r]) byRegion[r] = [];
  byRegion[r].push(t);
});
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>Temple Hub — 1080 사찰 홈페이지</title>
  <meta name="description" content="한국 1080 불교 사찰 공식 홈페이지 포털" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;700;900&display=swap" rel="stylesheet" />
</head>
<body>

  <header style="background:#C8372D;padding:3rem 1.4rem 2.5rem;text-align:center;">
    <span style="font-size:2.5rem;">🪷</span>
    <h1 style="font-family:var(--font,serif);font-size:clamp(2rem,5vw,3.2rem);font-weight:900;color:#fff;letter-spacing:.1em;margin-top:.5rem;">Temple Hub</h1>
    <p style="font-family:var(--font,serif);font-size:.85rem;letter-spacing:.2em;color:rgba(255,255,255,.75);margin-top:.4rem;">한국 1080 사찰 공식 홈페이지 포털</p>
    <p style="font-family:var(--font,serif);font-size:1.1rem;font-weight:700;color:rgba(255,255,255,.9);margin-top:.75rem;">{temples.length}개 사찰 운영 중</p>
    <div style="height:4px;background:linear-gradient(to right,#F0A830,#3A7D44,#2B5BA8);max-width:200px;margin:.8rem auto 0;border-radius:2px;"></div>
  </header>

  <main style="padding:3rem 0 5rem;">
    <div class="w">
      {Object.entries(byRegion).map(([region, list]) => (
        <div style="margin-bottom:3.5rem;">
          <h2 style="font-family:var(--font,serif);font-size:1.3rem;font-weight:800;letter-spacing:.1em;color:var(--ink,#1A120A);padding-bottom:.6rem;border-bottom:2px solid #C8372D;margin-bottom:1.5rem;">{region}</h2>
          <div style="display:grid;gap:1rem;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));">
            {list.map(t => (
              <a href={`/${t.slug}`} style="display:block;background:#fff;border-top:3px solid #C8372D;padding:1.4rem 1.5rem;box-shadow:0 2px 10px rgba(26,18,10,.07);transition:transform .2s,box-shadow .2s;"
                onmouseenter="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 24px rgba(26,18,10,.12)'"
                onmouseleave="this.style.transform='';this.style.boxShadow='0 2px 10px rgba(26,18,10,.07)'"
              >
                <h3 style="font-family:var(--font,serif);font-size:1.05rem;font-weight:700;color:var(--ink,#1A120A);letter-spacing:.05em;margin-bottom:.35rem;">{t.data.name}</h3>
                <p style="font-family:var(--font,serif);font-size:.72rem;color:var(--ink-3,#6B5340);letter-spacing:.06em;margin-bottom:.5rem;">{t.data.sect}</p>
                {t.data.slogan && <p style="font-family:var(--font,serif);font-size:.78rem;color:var(--ink-4,#9C7E65);line-height:1.75;font-style:italic;">{t.data.slogan.substring(0,50)}{t.data.slogan.length > 50 ? '…' : ''}</p>}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </main>

  <footer style="background:var(--ink,#1A120A);padding:2rem 1.4rem;text-align:center;">
    <p style="font-family:var(--font,serif);font-size:.72rem;letter-spacing:.1em;color:rgba(255,255,255,.3);">Temple Hub © {new Date().getFullYear()} · Powered by Astro</p>
  </footer>

</body>
</html>
