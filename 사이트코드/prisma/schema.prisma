generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Temple {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  nameEn         String?
  description    String?  @db.Text
  logoUrl        String?
  heroImageUrl   String?
  address        String?
  phone          String?
  email          String?
  primaryColor   String   @default("#8B2500")
  secondaryColor String   @default("#C5A572")
  fontFamily     String   @default("Pretendard")
  customDomain   String?  @unique
  subdomain      String?  @unique
  denomination   String?
  foundedYear    Int?
  abbotName      String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  posts       Post[]
  galleries   Gallery[]
  events      Event[]
  members     TempleMember[]
  domainMaps  DomainMap[]

  @@index([code])
  @@index([customDomain])
}

model DomainMap {
  id        String   @id @default(cuid())
  domain    String   @unique
  templeId  String
  temple    Temple   @relation(fields: [templeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@index([domain])
}

model Post {
  id          String       @id @default(cuid())
  templeId    String
  temple      Temple       @relation(fields: [templeId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  content     String       @db.Text
  excerpt     String?      @db.Text
  coverImage  String?
  category    PostCategory @default(NOTICE)
  isPublished Boolean      @default(false)
  publishedAt DateTime?
  authorId    String?
  author      User?        @relation(fields: [authorId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([templeId, slug])
  @@index([templeId, category])
}

enum PostCategory {
  NOTICE
  DHARMA_TALK
  NEWS
  COLUMN
}

model Gallery {
  id          String         @id @default(cuid())
  templeId    String
  temple      Temple         @relation(fields: [templeId], references: [id], onDelete: Cascade)
  title       String
  description String?        @db.Text
  images      GalleryImage[]
  isPublished Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  @@index([templeId])
}

model GalleryImage {
  id        String  @id @default(cuid())
  galleryId String
  gallery   Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  width     Int?
  height    Int?
  order     Int     @default(0)
  @@index([galleryId])
}

model Event {
  id          String   @id @default(cuid())
  templeId    String
  temple      Temple   @relation(fields: [templeId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  location    String?
  startDate   DateTime
  endDate     DateTime?
  isRecurring Boolean  @default(false)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([templeId, startDate])
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  role          UserRole       @default(MEMBER)
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  templeMembers TempleMember[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum UserRole {
  SUPER_ADMIN
  TEMPLE_ADMIN
  EDITOR
  MEMBER
}

model TempleMember {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  templeId  String
  temple    Temple           @relation(fields: [templeId], references: [id], onDelete: Cascade)
  role      TempleMemberRole @default(VIEWER)
  createdAt DateTime         @default(now())
  @@unique([userId, templeId])
  @@index([templeId])
}

enum TempleMemberRole {
  ADMIN
  EDITOR
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}
