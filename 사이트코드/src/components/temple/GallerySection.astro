---
// src/components/temple/GallerySection.astro — 3×3 고정 9장 + 모바일 대응
import { gallery as glUrl } from '../../lib/cloudinary';
import type { TempleData } from '../../content/config';
interface Props { d: TempleData; }
const { d } = Astro.props;

type GItem = { id:string; src:string; cap:string; tag:string; };
let raw: GItem[] = [];

if (d.gallery?.length) {
  raw = d.gallery.map(g => ({
    id:  g.id,
    src: glUrl(g.id, 640, 480),
    cap: g.cap ?? '',
    tag: g.tag ?? '',
  }));
} else if (d.gallery_imgs?.length) {
  raw = d.gallery_imgs.map(id => ({ id, src: glUrl(id, 640, 480), cap:'', tag:'' }));
}

// 9장 고정 — 부족하면 앞에서 반복 채움
const items: GItem[] = [];
if (raw.length > 0) {
  for (let i = 0; i < 9; i++) items.push(raw[i % raw.length]);
}
const tagColors = ['#C8372D','#2B5BA8','#3A7D44','#D4820A'];
const show = items.length > 0;
---

{show && (
  <section id="gallery" class="gal-sec" aria-labelledby="gal-ttl">
    <div class="w">
      <span class="sec-en" style="color:#3A7D44;">photo gallery</span>
      <h2 id="gal-ttl" class="sec-h2 gal-h2">사찰갤러리</h2>
      <div class="dc-bar"><span class="b3"></span><span class="b2"></span><span class="b1"></span><span class="b4"></span></div>

      <div class="gal-grid">
        {items.map((g, i) => (
          <div class="gi">
            <img src={g.src} alt={g.cap || `사찰 사진 ${i+1}`}
              loading={i < 3 ? 'eager' : 'lazy'}
              onerror="this.parentElement.style.background='#e8e0d5'" />
            <div class="gi-ov"></div>
            {g.tag && <span class="gal-tag" style={`background:${tagColors[i%4]}`}>{g.tag}</span>}
            {g.cap && <div class="gi-cap"><p class="gc-t">{g.cap}</p></div>}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .gal-sec { background:var(--bg,#FDFAF4);padding:5.5rem 0 6rem;scroll-margin-top:64px; }
  .gal-h2  { font-size:clamp(2rem,4.5vw,3rem);margin-top:.3rem; }

  .gal-grid {
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:6px;
  }
  @media(max-width:480px)  { .gal-grid{grid-template-columns:1fr} .gi{height:200px!important} }
  @media(min-width:481px) and (max-width:767px) { .gal-grid{grid-template-columns:repeat(2,1fr)} .gi{height:200px!important} }

  .gi {
    position:relative;overflow:hidden;height:240px;
    background:var(--bg2,#F5EFE0);
  }
  .gi img { width:100%;height:100%;object-fit:cover;transition:transform .6s cubic-bezier(.22,1,.36,1);display:block; }
  .gi:hover img { transform:scale(1.06); }
  .gi-ov { position:absolute;inset:0;background:linear-gradient(to top,rgba(26,18,10,.75) 0%,transparent 50%);opacity:0;transition:opacity .3s; }
  .gi:hover .gi-ov { opacity:1; }
  .gi-cap { position:absolute;bottom:0;inset-x:0;padding:.75rem 1rem;opacity:0;transform:translateY(6px);transition:opacity .3s,transform .3s; }
  .gi:hover .gi-cap { opacity:1;transform:translateY(0); }
  .gc-t { font-family:var(--font,serif);font-size:.88rem;font-weight:700;color:#fff;letter-spacing:.05em; }
  .gal-tag { position:absolute;top:.6rem;left:.6rem;z-index:2;padding:.1rem .5rem;font-family:var(--font,serif);font-size:.6rem;letter-spacing:.12em;color:#fff; }
</style>
